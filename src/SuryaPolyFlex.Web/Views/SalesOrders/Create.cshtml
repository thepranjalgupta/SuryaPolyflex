@model SuryaPolyFlex.Application.Features.SalesOrders.CreateSODto
@{
    ViewData["Title"] = "New Sales Order";
    var itemsList = ViewBag.Items as List<SuryaPolyFlex.Application.Features.Items.ItemSelectDto>
                    ?? new List<SuryaPolyFlex.Application.Features.Items.ItemSelectDto>();
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white"><h5 class="mb-0">New Sales Order</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post" id="soForm">
            @Html.AntiForgeryToken()
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="CustomerId" class="form-label fw-semibold">Customer <span class="text-danger">*</span></label>
                    <select asp-for="CustomerId" asp-items="ViewBag.Customers" class="form-select">
                        <option value="">-- Select --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="RequiredByDate" class="form-label fw-semibold">Required By Date</label>
                    <input asp-for="RequiredByDate" class="form-control" type="date" />
                </div>
                <div class="col-md-4">
                    <label asp-for="POReference" class="form-label fw-semibold">Customer PO Ref</label>
                    <input asp-for="POReference" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Remarks" class="form-label fw-semibold">Remarks</label>
                    <input asp-for="Remarks" class="form-control" />
                </div>
            </div>

            <h6 class="fw-semibold mb-2">Order Items <span class="text-danger">*</span></h6>
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Description</th>
                        <th style="width:110px">Qty</th>
                        <th style="width:120px">Unit Rate (₹)</th>
                        <th style="width:120px">Line Total</th>
                        <th style="width:50px"></th>
                    </tr>
                </thead>
                <tbody id="soBody"></tbody>
            </table>

            <div id="noSOItemsMsg" class="text-muted small mb-2">No items added yet.</div>
            <div class="d-flex justify-content-between mb-3">
                <button type="button" class="btn btn-sm btn-outline-primary"
                        onclick="addSORow()">+ Add Item</button>
                <div class="fw-semibold">Total: ₹<span id="soTotal">0.00</span></div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Sales Order</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    let soIndex = 0;

    function addSORow() {
        document.getElementById('noSOItemsMsg').style.display = 'none';
        const tbody = document.getElementById('soBody');
        const tr    = document.createElement('tr');
        tr.innerHTML = `
            <td>
                <input type="text" name="Items[${soIndex}].Description"
                       class="form-control form-control-sm" required />
            </td>
            <td>
                <input type="number" name="Items[${soIndex}].OrderedQty"
                       class="form-control form-control-sm so-qty"
                       step="0.001" min="0.001" value="1" required
                       oninput="updateSOTotal()" />
            </td>
            <td>
                <input type="number" name="Items[${soIndex}].UnitRate"
                       class="form-control form-control-sm so-rate"
                       step="0.01" min="0.01" value="0" required
                       oninput="updateSOTotal()" />
            </td>
            <td class="so-line text-end fw-semibold">₹0.00</td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger"
                        onclick="this.closest('tr').remove(); updateSOTotal()">✕</button>
            </td>`;
        tbody.appendChild(tr);
        soIndex++;
        reindexSO();
    }

    function reindexSO() {
        document.getElementById('soBody').querySelectorAll('tr').forEach((row, i) => {
            row.querySelectorAll('[name]').forEach(el => {
                el.name = el.name.replace(/Items\[\d+\]/, `Items[${i}]`);
            });
        });
        soIndex = document.getElementById('soBody').querySelectorAll('tr').length;
    }

    function updateSOTotal() {
        let total = 0;
        document.getElementById('soBody').querySelectorAll('tr').forEach(row => {
            const qty  = parseFloat(row.querySelector('.so-qty')?.value)  || 0;
            const rate = parseFloat(row.querySelector('.so-rate')?.value) || 0;
            const line = qty * rate;
            const cell = row.querySelector('.so-line');
            if (cell) cell.textContent = '₹' + line.toFixed(2);
            total += line;
        });
        document.getElementById('soTotal').textContent = total.toFixed(2);
    }

    document.getElementById('soForm').addEventListener('submit', function(e) {
        if (document.getElementById('soBody').children.length === 0) {
            e.preventDefault();
            alert('Please add at least one item.');
        }
    });
</script>