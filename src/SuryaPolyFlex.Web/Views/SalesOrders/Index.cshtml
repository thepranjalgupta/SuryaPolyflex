@model List<SuryaPolyFlex.Application.Features.SalesOrders.SalesOrderDto>
@{ ViewData["Title"] = "Sales Orders"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Sales Orders</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ New Sales Order</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="get" class="d-flex gap-2 mb-3">
            <select name="status" class="form-select form-select-sm w-auto">
                <option value="">All Statuses</option>
                @foreach (var s in new[]{"Open","InProduction","ReadyToDispatch","Dispatched","Delivered","Closed","Cancelled"})
                {
                    <option value="@s" selected="@(ViewBag.Status == s)">@s</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-secondary">Filter</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-danger">Clear</a>
        </form>

        <table class="table table-hover table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>SO Number</th><th>Date</th><th>Customer</th>
                    <th>PO Ref</th><th>Amount</th><th>Required By</th>
                    <th>Status</th><th style="width:100px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted">No sales orders found.</td></tr>
                }
                @foreach (var so in Model)
                {
                    <tr>
                        <td class="fw-semibold text-primary">@so.SONumber</td>
                        <td class="small">@so.SODate.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>@so.CustomerName</td>
                        <td class="small">@so.POReference</td>
                        <td>₹@so.TotalAmount.ToString("N2")</td>
                        <td class="small @(so.RequiredByDate < DateTime.Now && so.Status == "Open" ? "text-danger fw-semibold" : "")">
                            @so.RequiredByDate?.ToString("dd MMM yyyy")
                        </td>
                        <td>
                            @{
                                var c = so.Status switch {
                                    "Open"             => "bg-primary",
                                    "InProduction"     => "bg-info text-dark",
                                    "ReadyToDispatch"  => "bg-warning text-dark",
                                    "Dispatched"       => "bg-secondary",
                                    "Delivered"        => "bg-success",
                                    "Closed"           => "bg-success",
                                    "Cancelled"        => "bg-danger",
                                    _                  => "bg-secondary"
                                };
                            }
                            <span class="badge @c">@so.Status</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@so.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>