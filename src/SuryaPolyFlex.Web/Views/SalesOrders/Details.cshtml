@model SuryaPolyFlex.Application.Features.SalesOrders.SalesOrderDto
@{ ViewData["Title"] = "Sales Order Details"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Sales Order — @Model.SONumber</h4>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <small class="text-muted">Customer</small>
                <div class="fw-semibold">@Model.CustomerName</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">SO Date</small>
                <div>@Model.SODate.ToLocalTime().ToString("dd MMM yyyy")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Required By</small>
                <div>@Model.RequiredByDate?.ToString("dd MMM yyyy")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Status</small>
                <div>
                    @{
                        var c = Model.Status switch {
                            "Open"            => "bg-primary",
                            "InProduction"    => "bg-info text-dark",
                            "ReadyToDispatch" => "bg-warning text-dark",
                            "Dispatched"      => "bg-secondary",
                            "Delivered"       => "bg-success",
                            _                 => "bg-secondary"
                        };
                    }
                    <span class="badge @c">@Model.Status</span>
                </div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">PO Reference</small>
                <div>@Model.POReference</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Total Amount</small>
                <div class="fw-semibold text-success">₹@Model.TotalAmount.ToString("N2")</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header fw-semibold">Order Items</div>
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr><th>#</th><th>Description</th><th>UoM</th><th>Ordered</th><th>Dispatched</th><th>Pending</th><th>Rate</th><th>Total</th></tr>
            </thead>
            <tbody>
                @{ int sr = 1; }
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@sr++</td>
                        <td>@item.Description</td>
                        <td>@item.UoMCode</td>
                        <td>@item.OrderedQty</td>
                        <td class="text-success fw-semibold">@item.DispatchedQty</td>
                        <td class="text-warning fw-semibold">@item.PendingQty</td>
                        <td>₹@item.UnitRate</td>
                        <td>₹@item.LineTotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.CustomerJobs.Any())
{
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold d-flex justify-content-between">
            Customer Jobs
            <a asp-action="AddJob" asp-route-id="@Model.Id"
               class="btn btn-sm btn-outline-primary">+ Add Job</a>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr><th>Job Title</th><th>Substrate</th><th>Size</th><th>Colors</th><th>Qty</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @foreach (var job in Model.CustomerJobs)
                    {
                        <tr>
                            <td class="fw-semibold">@job.JobTitle</td>
                            <td>@job.Substrate</td>
                            <td class="small">@job.Width × @job.Length</td>
                            <td>@job.ColorCount</td>
                            <td>@job.Quantity</td>
                            <td><span class="badge bg-secondary">@job.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="mb-3">
        <a asp-action="AddJob" asp-route-id="@Model.Id"
           class="btn btn-outline-primary btn-sm">+ Add Customer Job</a>
    </div>
}

<div class="d-flex gap-2">
    @if (Model.Status == "Open")
    {
        <form asp-action="UpdateStatus" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="status" value="InProduction" />
            <button class="btn btn-info text-white">→ Move to Production</button>
        </form>
    }
    @if (Model.Status == "InProduction")
    {
        <form asp-action="UpdateStatus" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="status" value="ReadyToDispatch" />
            <button class="btn btn-warning">→ Ready to Dispatch</button>
        </form>
    }
    @if (Model.Status == "ReadyToDispatch" || Model.Status == "InProduction")
{
    <a asp-controller="Dispatch" asp-action="CreateChallan"
       asp-route-soId="@Model.Id"
       class="btn btn-warning">→ Create Delivery Challan</a>
}
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>