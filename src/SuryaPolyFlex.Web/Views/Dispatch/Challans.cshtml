@model List<SuryaPolyFlex.Application.Features.Dispatch.DeliveryChallanDto>
@{ ViewData["Title"] = "Delivery Challans"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Delivery Challans</h4>
    <a asp-action="CreateChallan" class="btn btn-primary btn-sm">+ New Challan</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Challan No</th><th>Date</th><th>Sales Order</th>
                    <th>Customer</th><th>Transporter</th><th>Vehicle</th>
                    <th>Value</th><th>Status</th><th>Shipment</th>
                    <th style="width:80px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="10" class="text-center text-muted">No challans found.</td></tr>
                }
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="fw-semibold text-primary">@c.ChallanNo</td>
                        <td class="small">@c.ChallanDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>@c.SONumber</td>
                        <td>@c.CustomerName</td>
                        <td class="small">@c.TransporterName</td>
                        <td class="small">@c.VehicleNumber</td>
                        <td>₹@c.TotalValue.ToString("N2")</td>
                        <td>
                            @{
                                var cs = c.Status switch {
                                    "Prepared"  => "bg-secondary",
                                    "Delivered" => "bg-success",
                                    _           => "bg-info text-dark"
                                };
                            }
                            <span class="badge @cs">@c.Status</span>
                        </td>
                        <td>
                            @if (c.ShipmentStatus != null)
                            {
                                var ss = c.ShipmentStatus switch {
                                    "Dispatched"      => "bg-secondary",
                                    "InTransit"       => "bg-primary",
                                    "OutForDelivery"  => "bg-warning text-dark",
                                    "Delivered"       => "bg-success",
                                    _                 => "bg-secondary"
                                };
                                <span class="badge @ss">@c.ShipmentStatus</span>
                            }
                        </td>
                        <td>
                            <a asp-action="ChallanDetails" asp-route-id="@c.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>