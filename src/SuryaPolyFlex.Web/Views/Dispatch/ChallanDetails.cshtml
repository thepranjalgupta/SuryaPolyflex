@model SuryaPolyFlex.Application.Features.Dispatch.DeliveryChallanDto
@{ ViewData["Title"] = "Challan Details"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Delivery Challan — @Model.ChallanNo</h4>
    <a asp-action="Challans" class="btn btn-sm btn-outline-secondary">← Back</a>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <small class="text-muted">Sales Order</small>
                <div class="fw-semibold">@Model.SONumber</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Customer</small>
                <div>@Model.CustomerName</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Transporter</small>
                <div>@(Model.TransporterName ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Vehicle No</small>
                <div>@(Model.VehicleNumber ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">LR Number</small>
                <div>@(Model.LRNumber ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">E-Way Bill</small>
                <div>@(Model.EWayBillNo ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Total Value</small>
                <div class="fw-semibold text-success">₹@Model.TotalValue.ToString("N2")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Shipment Status</small>
                <div>
                    @if (Model.ShipmentStatus != null)
                    {
                        var ss = Model.ShipmentStatus switch {
                            "Dispatched"     => "bg-secondary",
                            "InTransit"      => "bg-primary",
                            "OutForDelivery" => "bg-warning text-dark",
                            "Delivered"      => "bg-success",
                            _                => "bg-secondary"
                        };
                        <span class="badge @ss">@Model.ShipmentStatus</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header fw-semibold">Items</div>
    <div class="card-body p-0">
        <table class="table table-sm mb-0">
            <thead class="table-light">
                <tr><th>#</th><th>Item</th><th>UoM</th><th>Qty</th><th>Rate</th><th>Total</th></tr>
            </thead>
            <tbody>
                @{ int sr = 1; }
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@sr++</td>
                        <td>
                            <span class="badge bg-secondary">@item.ItemCode</span>
                            @item.ItemName
                        </td>
                        <td>@item.UoMCode</td>
                        <td class="fw-semibold">@item.DispatchedQty</td>
                        <td>₹@item.UnitRate</td>
                        <td>₹@item.LineTotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-light fw-semibold">
                    <td colspan="5" class="text-end">Total</td>
                    <td>₹@Model.TotalValue.ToString("N2")</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@if (Model.ShipmentStatus != null && Model.ShipmentStatus != "Delivered")
{
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">Update Shipment Status</div>
        <div class="card-body">
            <form asp-action="UpdateShipment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ChallanId" value="@Model.Id" />
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Status <span class="text-danger">*</span></label>
                        <select name="Status" class="form-select" required>
                            <option value="Dispatched">Dispatched</option>
                            <option value="InTransit">In Transit</option>
                            <option value="OutForDelivery">Out For Delivery</option>
                            <option value="Delivered">Delivered</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">ETA</label>
                        <input name="EstimatedDeliveryDate" class="form-control" type="date" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Actual Delivery Date</label>
                        <input name="ActualDeliveryDate" class="form-control" type="date" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Receiver Name</label>
                        <input name="ReceiverName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Delivery Remarks</label>
                        <input name="DeliveryRemarks" class="form-control" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary mt-3">Update Status</button>
            </form>
        </div>
    </div>
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>