@model SuryaPolyFlex.Application.Features.Leads.EditLeadDto
@{ ViewData["Title"] = "Edit Lead"; }
<div class="card shadow-sm mx-auto" style="max-width:600px">
    <div class="card-header bg-warning"><h5 class="mb-0">Edit Lead</h5></div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Title" class="form-label fw-semibold">Title</label>
                    <input asp-for="Title" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="CustomerId" class="form-label fw-semibold">Customer</label>
                    <select asp-for="CustomerId" asp-items="ViewBag.Customers" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Status" class="form-label fw-semibold">Status</label>
                    <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="ContactPerson" class="form-label fw-semibold">Contact Person</label>
                    <input asp-for="ContactPerson" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label fw-semibold">Phone</label>
                    <input asp-for="Phone" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="FollowUpDate" class="form-label fw-semibold">Follow Up Date</label>
                    <input asp-for="FollowUpDate" class="form-control" type="date" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Source" class="form-label fw-semibold">Source</label>
                    <input asp-for="Source" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Remarks" class="form-label fw-semibold">Remarks</label>
                    <textarea asp-for="Remarks" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning">Update</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />