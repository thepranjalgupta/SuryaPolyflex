@{ ViewData["Title"] = "Stock Ledger"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Stock Ledger</h4>
    <a asp-action="Balance" class="btn btn-outline-primary btn-sm">← Stock Balance</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2">
            <div class="col-md-3">
                <select name="warehouseId" class="form-select form-select-sm">
                    <option value="">All Warehouses</option>
                    @foreach (SelectListItem w in ViewBag.Warehouses)
                    {
                        <option value="@w.Value"
                                selected="@(w.Value == ViewBag.WarehouseId?.ToString())">
                            @w.Text
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="from" value="@ViewBag.From"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <input type="date" name="to" value="@ViewBag.To"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-sm btn-outline-secondary w-100">Filter</button>
            </div>
            <div class="col-md-2">
                <a asp-action="Ledger" class="btn btn-sm btn-outline-danger w-100">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-sm align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Date</th><th>Item</th><th>Warehouse</th>
                    <th>Type</th><th>Reference</th>
                    <th>Inward</th><th>Outward</th><th>Balance</th>
                    <th>Rate</th><th>By</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="10" class="text-center text-muted py-3">No ledger entries found.</td></tr>
                }
                @foreach (var l in Model)
                {
                    <tr>
                        <td class="small">@l.Date.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                        <td>
                            <span class="badge bg-secondary">@l.ItemCode</span>
                            <span class="small">@l.ItemName</span>
                        </td>
                        <td class="small">@l.Warehouse</td>
                        <td><span class="badge bg-info text-dark small">@l.TransactionType</span></td>
                        <td class="small">@l.ReferenceNumber</td>
                        <td class="text-success fw-semibold">
                            @(l.InwardQty > 0 ? l.InwardQty.ToString() : "—")
                        </td>
                        <td class="text-danger fw-semibold">
                            @(l.OutwardQty > 0 ? l.OutwardQty.ToString() : "—")
                        </td>
                        <td class="fw-semibold">@l.BalanceQty</td>
                        <td class="small">@(l.UnitCost > 0 ? $"₹{l.UnitCost}" : "—")</td>
                        <td class="small text-muted">@l.CreatedBy</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>