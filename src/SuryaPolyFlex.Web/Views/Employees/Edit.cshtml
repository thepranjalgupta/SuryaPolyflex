@model SuryaPolyFlex.Application.Features.Employees.EditEmployeeDto
@{ ViewData["Title"] = "Edit Employee"; }

<div class="card shadow-sm mx-auto" style="max-width:560px">
    <div class="card-header bg-warning">
        <h5 class="mb-0">Edit Employee</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="EmployeeCode" class="form-label fw-semibold">
                        Employee Code <span class="text-danger">*</span>
                    </label>
                    <input asp-for="EmployeeCode" class="form-control" />
                    <span asp-validation-for="EmployeeCode" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label fw-semibold">
                        Full Name <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Designation" class="form-label fw-semibold">Designation</label>
                    <input asp-for="Designation" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label asp-for="DepartmentId" class="form-label fw-semibold">
                        Department <span class="text-danger">*</span>
                    </label>
                    <select asp-for="DepartmentId" asp-items="ViewBag.Departments"
                            class="form-select">
                        <option value="">-- Select Department --</option>
                    </select>
                    <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label fw-semibold">Phone</label>
                    <input asp-for="Phone" class="form-control" />
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Active</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning">Update</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />