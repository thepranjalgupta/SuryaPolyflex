@model List<SuryaPolyFlex.Application.Features.Items.ItemDto>
@{ ViewData["Title"] = "Items"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Items / Materials</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Add Item</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="get" class="d-flex gap-2 mb-3">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control form-control-sm w-25" placeholder="Search code or name..." />
            <select name="itemType" class="form-select form-select-sm w-auto">
                <option value="">All Types</option>
                <option value="RM" selected="@(ViewBag.ItemType == "RM")">Raw Material</option>
                <option value="FG" selected="@(ViewBag.ItemType == "FG")">Finished Goods</option>
                <option value="WIP" selected="@(ViewBag.ItemType == "WIP")">WIP</option>
                <option value="Consumable" selected="@(ViewBag.ItemType == "Consumable")">Consumable</option>
            </select>
            <button class="btn btn-sm btn-outline-secondary">Search</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-danger">Clear</a>
        </form>

        <table class="table table-hover table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Code</th><th>Name</th><th>Category</th>
                    <th>Type</th><th>UoM</th><th>Min Stock</th>
                    <th>Std Cost</th><th>Status</th><th style="width:110px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted">No items found.</td></tr>
                }
                @foreach (var i in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@i.ItemCode</span></td>
                        <td class="fw-semibold">@i.Name</td>
                        <td class="small">@i.CategoryName</td>
                        <td>
                            <span class="badge bg-info text-dark">@i.ItemType</span>
                        </td>
                        <td class="small">@i.UoMCode</td>
                        <td class="small">@i.MinStockLevel</td>
                        <td class="small">₹@i.StandardCost</td>
                        <td>
                            <span class="badge @(i.IsActive ? "bg-success" : "bg-danger")">
                                @(i.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@i.Id"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-action="Delete" asp-route-id="@i.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this item?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger">Del</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>