@model SuryaPolyFlex.Application.Features.Items.CreateItemDto
@{ ViewData["Title"] = "Add Item"; }

<div class="card shadow-sm mx-auto" style="max-width:640px">
    <div class="card-header bg-primary text-white"><h5 class="mb-0">Add Item</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="ItemCode" class="form-label fw-semibold">Item Code <span class="text-danger">*</span></label>
                    <input asp-for="ItemCode" class="form-control" placeholder="e.g. INK001" />
                    <span asp-validation-for="ItemCode" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label fw-semibold">Item Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-md-4">
                    <label asp-for="CategoryId" class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                        <option value="">-- Select --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="UoMId" class="form-label fw-semibold">Unit of Measure <span class="text-danger">*</span></label>
                    <select asp-for="UoMId" asp-items="ViewBag.UoMs" class="form-select">
                        <option value="">-- Select --</option>
                    </select>
                    <span asp-validation-for="UoMId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ItemType" class="form-label fw-semibold">Item Type <span class="text-danger">*</span></label>
                    <select asp-for="ItemType" asp-items="ViewBag.ItemTypes" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="MinStockLevel" class="form-label fw-semibold">Min Stock Level</label>
                    <input asp-for="MinStockLevel" class="form-control" type="number" step="0.001" />
                </div>
                <div class="col-md-4">
                    <label asp-for="ReorderQty" class="form-label fw-semibold">Reorder Qty</label>
                    <input asp-for="ReorderQty" class="form-control" type="number" step="0.001" />
                </div>
                <div class="col-md-4">
                    <label asp-for="StandardCost" class="form-label fw-semibold">Standard Cost (₹)</label>
                    <input asp-for="StandardCost" class="form-control" type="number" step="0.01" />
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Item</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />