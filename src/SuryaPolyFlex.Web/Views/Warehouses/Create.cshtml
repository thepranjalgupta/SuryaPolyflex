@model SuryaPolyFlex.Application.Features.Warehouses.CreateWarehouseDto
@{ ViewData["Title"] = "Add Warehouse"; }
<div class="card shadow-sm mx-auto" style="max-width:480px">
    <div class="card-header bg-primary text-white"><h5 class="mb-0">Add Warehouse</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Code" class="form-label fw-semibold">Code <span class="text-danger">*</span></label>
                <input asp-for="Code" class="form-control" />
                <span asp-validation-for="Code" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="WarehouseType" class="form-label fw-semibold">Type <span class="text-danger">*</span></label>
                <select asp-for="WarehouseType" asp-items="ViewBag.WarehouseTypes" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Location" class="form-label fw-semibold">Location</label>
                <input asp-for="Location" class="form-control" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />