@model SuryaPolyFlex.Application.Features.Warehouses.EditWarehouseDto
@{ ViewData["Title"] = "Edit Warehouse"; }
<div class="card shadow-sm mx-auto" style="max-width:480px">
    <div class="card-header bg-warning"><h5 class="mb-0">Edit Warehouse</h5></div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div class="mb-3">
                <label asp-for="Code" class="form-label fw-semibold">Code</label>
                <input asp-for="Code" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Name</label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="WarehouseType" class="form-label fw-semibold">Type</label>
                <select asp-for="WarehouseType" asp-items="ViewBag.WarehouseTypes" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Location" class="form-label fw-semibold">Location</label>
                <input asp-for="Location" class="form-control" />
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Update</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />