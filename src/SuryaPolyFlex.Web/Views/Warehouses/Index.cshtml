@model List<SuryaPolyFlex.Application.Features.Warehouses.WarehouseDto>
@{ ViewData["Title"] = "Warehouses"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Warehouses</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Add Warehouse</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-dark">
                <tr><th>Code</th><th>Name</th><th>Type</th><th>Location</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var w in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@w.Code</span></td>
                        <td class="fw-semibold">@w.Name</td>
                        <td><span class="badge bg-info text-dark">@w.WarehouseType</span></td>
                        <td class="small text-muted">@w.Location</td>
                        <td>
                            <span class="badge @(w.IsActive ? "bg-success" : "bg-danger")">
                                @(w.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@w.Id"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>