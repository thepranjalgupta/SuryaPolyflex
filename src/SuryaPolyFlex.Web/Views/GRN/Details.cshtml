@model SuryaPolyFlex.Application.Features.GRN.GRNDto
@{ ViewData["Title"] = "GRN Details"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">GRN — @Model.GRNNumber</h4>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <small class="text-muted">GRN Date</small>
                <div class="fw-semibold">@Model.GRNDate.ToLocalTime().ToString("dd MMM yyyy")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">PO Number</small>
                <div class="fw-semibold">@Model.PONumber</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Vendor</small>
                <div>@Model.VendorName</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Status</small>
                <div>
                    @{
                        var c = Model.Status switch {
                            "Pending"  => "bg-warning text-dark",
                            "Accepted" => "bg-success",
                            _          => "bg-secondary"
                        };
                    }
                    <span class="badge @c">@Model.Status</span>
                </div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Warehouse</small>
                <div>@Model.WarehouseName</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Vehicle No</small>
                <div>@Model.VehicleNumber</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header fw-semibold">Items</div>
    <div class="card-body p-0">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th><th>Item</th><th>UoM</th>
                    <th>Received</th><th>Accepted</th>
                    <th>Rejected</th><th>Unit Cost</th>
                </tr>
            </thead>
            <tbody>
                @{ int sr = 1; }
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@sr++</td>
                        <td>
                            <span class="badge bg-secondary">@item.ItemCode</span>
                            @item.ItemName
                        </td>
                        <td>@item.UoMCode</td>
                        <td>@item.ReceivedQty</td>
                        <td class="text-success fw-semibold">@item.AcceptedQty</td>
                        <td class="text-danger">@item.RejectedQty</td>
                        <td>₹@item.UnitCost</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.Status == "Pending")
{
    <form asp-action="Accept" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <button class="btn btn-success"
                onclick="return confirm('Accept GRN and update stock?')">
            ✓ Accept GRN &amp; Update Stock
        </button>
    </form>
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>