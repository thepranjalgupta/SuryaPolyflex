@model SuryaPolyFlex.Application.Features.GRN.CreateGRNViewModel
@{ ViewData["Title"] = "New GRN"; }

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">New Goods Receipt Note</h5>
    </div>
    <div class="card-body">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@e.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        Purchase Order <span class="text-danger">*</span>
                    </label>
                    <select id="PurchaseOrderId" name="PurchaseOrderId"
                            class="form-select" required>
                        <option value="">-- Select PO --</option>
                        @foreach (SelectListItem po in ViewBag.PurchaseOrders)
                        {
                            <option value="@po.Value"
                                    selected="@(po.Value == Model.Form.PurchaseOrderId.ToString())">
                                @po.Text
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">
                        Receive Into Warehouse <span class="text-danger">*</span>
                    </label>
                    <select name="WarehouseId" class="form-select" required>
                        <option value="">-- Select Warehouse --</option>
                        @foreach (SelectListItem w in ViewBag.Warehouses)
                        {
                            <option value="@w.Value">@w.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Vehicle Number</label>
                    <input name="VehicleNumber" class="form-control"
                           value="@Model.Form.VehicleNumber" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Delivery Note No</label>
                    <input name="DeliveryNoteNumber" class="form-control"
                           value="@Model.Form.DeliveryNoteNumber" />
                </div>
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Remarks</label>
                    <input name="Remarks" class="form-control"
                           value="@Model.Form.Remarks" />
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="fw-semibold mb-0">Items</h6>
                @if (Model.Lines.Any())
                {
                    <button type="button" class="btn btn-sm btn-outline-primary" id="addGrnItemBtn" onclick="addGrnItemRow()">+ Add Item</button>
                }
            </div>

            @if (Model.Lines.Any())
            {
                <table class="table table-sm table-bordered" id="grnItemsTable">
                    <thead class="table-light">
                        <tr>
                            <th>Item</th>
                            <th>UoM</th>
                            <th style="width:130px">Received Qty</th>
                            <th style="width:130px">Accepted Qty</th>
                            <th style="width:130px">Unit Cost (₹)</th>
                            <th style="width:180px">Rejection Reason</th>
                            <th style="width:50px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Lines.Count; i++)
                        {
                            var line = Model.Lines[i];
                            <input type="hidden" name="Items[@i].POItemId" value="@line.POItemId" />
                            <input type="hidden" name="Items[@i].ItemId"   value="@line.ItemId" />
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">@line.ItemCode</span>
                                    @line.ItemName
                                </td>
                                <td>@line.UoMCode</td>
                                <td>
                                    <input type="number"
                                           name="Items[@i].ReceivedQty"
                                           class="form-control form-control-sm"
                                           value="@line.PendingQty"
                                           step="0.001" min="0" required />
                                </td>
                                <td>
                                    <input type="number"
                                           name="Items[@i].AcceptedQty"
                                           class="form-control form-control-sm"
                                           value="@line.PendingQty"
                                           step="0.001" min="0" required />
                                </td>
                                <td>
                                    <input type="number"
                                           name="Items[@i].UnitCost"
                                           class="form-control form-control-sm"
                                           value="@line.UnitCost"
                                           step="0.01" min="0" />
                                </td>
                                <td>
                                    <input type="text"
                                           name="Items[@i].RejectionReason"
                                           class="form-control form-control-sm" />
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeGrnRow(this)">−</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info">
                    Select a PO from the dropdown above, then navigate to
                    <strong>PO Details → Create GRN</strong> to pre-load items.
                    Or go back to
                    <a asp-controller="PurchaseOrders" asp-action="Index">Purchase Orders</a>
                    and click the <strong>GRN</strong> button on an open PO.
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary"
                        @(Model.Lines.Any() ? "" : "disabled")>
                    Save GRN
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var poSelect = document.getElementById('PurchaseOrderId');
        if (!poSelect) return;

        poSelect.addEventListener('change', function() {
            var val = this.value;
            if (!val) return;
            // reload the page with selected PO to auto-populate item lines
            window.location.href = '@Url.Action("Create", "GRN")?poId=' + encodeURIComponent(val);
        });
    });

    function addGrnItemRow() {
        var table = document.getElementById('grnItemsTable');
        if (!table) {
            alert('No items table found. Please select a PO first.');
            return;
        }

        var tbody = table.querySelector('tbody');
        var rowCount = tbody.querySelectorAll('tr').length;
        var newIndex = rowCount;

        var tr = document.createElement('tr');
        tr.innerHTML = `
            <input type="hidden" name="Items[${newIndex}].POItemId" value="0" />
            <input type="hidden" name="Items[${newIndex}].ItemId" value="0" />
            <td>
                <input type="text" class="form-control form-control-sm" placeholder="Item description" disabled />
            </td>
            <td>
                <input type="text" class="form-control form-control-sm" placeholder="UoM" disabled />
            </td>
            <td>
                <input type="number"
                       name="Items[${newIndex}].ReceivedQty"
                       class="form-control form-control-sm"
                       step="0.001" min="0" value="0" required />
            </td>
            <td>
                <input type="number"
                       name="Items[${newIndex}].AcceptedQty"
                       class="form-control form-control-sm"
                       step="0.001" min="0" value="0" required />
            </td>
            <td>
                <input type="number"
                       name="Items[${newIndex}].UnitCost"
                       class="form-control form-control-sm"
                       step="0.01" min="0" value="0" />
            </td>
            <td>
                <input type="text"
                       name="Items[${newIndex}].RejectionReason"
                       class="form-control form-control-sm" />
            </td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeGrnRow(this)">−</button>
            </td>
        `;
        tbody.appendChild(tr);
    }

    function removeGrnRow(btn) {
        var tbody = btn.closest('table').querySelector('tbody');
        var rows = tbody.querySelectorAll('tr');
        if (rows.length <= 1) {
            alert('Cannot remove the last item row.');
            return;
        }
        btn.closest('tr').remove();
        updateGrnRowIndexes();
    }

    function updateGrnRowIndexes() {
        var table = document.getElementById('grnItemsTable');
        if (!table) return;
        
        var tbody = table.querySelector('tbody');
        var rows = tbody.querySelectorAll('tr');
        rows.forEach((row, idx) => {
            row.querySelectorAll('[name]').forEach(el => {
                el.name = el.name.replace(/Items\[\d+\]/, `Items[${idx}]`);
            });
        });
    }
</script>