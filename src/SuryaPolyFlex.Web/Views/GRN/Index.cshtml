@model List<SuryaPolyFlex.Application.Features.GRN.GRNDto>
@{ ViewData["Title"] = "GRN"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Goods Receipt Notes</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ New GRN</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>GRN Number</th><th>Date</th><th>PO Number</th>
                    <th>Vendor</th><th>Vehicle No</th><th>Status</th>
                    <th style="width:100px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted">No GRNs found.</td></tr>
                }
                @foreach (var g in Model)
                {
                    <tr>
                        <td class="fw-semibold text-primary">@g.GRNNumber</td>
                        <td class="small">@g.GRNDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>@g.PONumber</td>
                        <td>@g.VendorName</td>
                        <td class="small">@g.VehicleNumber</td>
                        <td>
                            @{
                                var c = g.Status switch {
                                    "Pending"  => "bg-warning text-dark",
                                    "Accepted" => "bg-success",
                                    "QCFailed" => "bg-danger",
                                    _          => "bg-secondary"
                                };
                            }
                            <span class="badge @c">@g.Status</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@g.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>