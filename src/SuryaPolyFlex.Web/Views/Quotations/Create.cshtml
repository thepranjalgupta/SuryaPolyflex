@model SuryaPolyFlex.Application.Features.Quotations.CreateQuotationDto
@{
    ViewData["Title"] = "New Quotation";
    var itemsList = ViewBag.Items as List<SuryaPolyFlex.Application.Features.Items.ItemSelectDto>
                    ?? new List<SuryaPolyFlex.Application.Features.Items.ItemSelectDto>();
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white"><h5 class="mb-0">New Quotation</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post" id="qtnForm">
            @Html.AntiForgeryToken()
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="CustomerId" class="form-label fw-semibold">Customer <span class="text-danger">*</span></label>
                    <select asp-for="CustomerId" asp-items="ViewBag.Customers" class="form-select">
                        <option value="">-- Select --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="ValidUntil" class="form-label fw-semibold">Valid Until</label>
                    <input asp-for="ValidUntil" class="form-control" type="date" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Terms" class="form-label fw-semibold">Terms</label>
                    <input asp-for="Terms" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="Remarks" class="form-label fw-semibold">Remarks</label>
                    <input asp-for="Remarks" class="form-control" />
                </div>
            </div>

            <h6 class="fw-semibold mb-2">Line Items <span class="text-danger">*</span></h6>
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Description</th>
                        <th style="width:110px">Qty</th>
                        <th style="width:120px">Unit Rate (₹)</th>
                        <th style="width:90px">Disc %</th>
                        <th style="width:120px">Line Total</th>
                        <th style="width:50px"></th>
                    </tr>
                </thead>
                <tbody id="qtnBody"></tbody>
            </table>

            <div id="noItemsMsg" class="text-muted small mb-2">No items added yet.</div>
            <div class="d-flex justify-content-between mb-3">
                <button type="button" class="btn btn-sm btn-outline-primary"
                        onclick="addQtnRow()">+ Add Line</button>
                <div class="fw-semibold">Total: ₹<span id="qtnTotal">0.00</span></div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Quotation</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    let qtnIndex = 0;

    function addQtnRow() {
        document.getElementById('noItemsMsg').style.display = 'none';
        const tbody = document.getElementById('qtnBody');
        const tr    = document.createElement('tr');
        tr.innerHTML = `
            <td>
                <input type="text" name="Items[${qtnIndex}].Description"
                       class="form-control form-control-sm" required
                       placeholder="Product description" />
            </td>
            <td>
                <input type="number" name="Items[${qtnIndex}].Qty"
                       class="form-control form-control-sm qty"
                       step="0.001" min="0.001" value="1" required
                       oninput="updateQtnTotal()" />
            </td>
            <td>
                <input type="number" name="Items[${qtnIndex}].UnitRate"
                       class="form-control form-control-sm rate"
                       step="0.01" min="0.01" value="0" required
                       oninput="updateQtnTotal()" />
            </td>
            <td>
                <input type="number" name="Items[${qtnIndex}].DiscountPct"
                       class="form-control form-control-sm disc"
                       step="0.01" min="0" max="100" value="0"
                       oninput="updateQtnTotal()" />
            </td>
            <td class="line-total text-end fw-semibold">₹0.00</td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger"
                        onclick="this.closest('tr').remove(); updateQtnTotal()">✕</button>
            </td>`;
        tbody.appendChild(tr);
        qtnIndex++;
        reindexQtn();
    }

    function reindexQtn() {
        document.getElementById('qtnBody').querySelectorAll('tr').forEach((row, i) => {
            row.querySelectorAll('[name]').forEach(el => {
                el.name = el.name.replace(/Items\[\d+\]/, `Items[${i}]`);
            });
        });
        qtnIndex = document.getElementById('qtnBody').querySelectorAll('tr').length;
    }

    function updateQtnTotal() {
        let total = 0;
        document.getElementById('qtnBody').querySelectorAll('tr').forEach(row => {
            const qty  = parseFloat(row.querySelector('.qty')?.value)  || 0;
            const rate = parseFloat(row.querySelector('.rate')?.value) || 0;
            const disc = parseFloat(row.querySelector('.disc')?.value) || 0;
            const line = qty * rate * (1 - disc / 100);
            const cell = row.querySelector('.line-total');
            if (cell) cell.textContent = '₹' + line.toFixed(2);
            total += line;
        });
        document.getElementById('qtnTotal').textContent = total.toFixed(2);
    }

    document.getElementById('qtnForm').addEventListener('submit', function(e) {
        if (document.getElementById('qtnBody').children.length === 0) {
            e.preventDefault();
            alert('Please add at least one line item.');
        }
    });
</script>