@model SuryaPolyFlex.Application.Features.Production.JobCardDto
@{ ViewData["Title"] = "Job Card Details"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Job Card — @Model.JobCardNo</h4>
    <a asp-action="JobCards" class="btn btn-sm btn-outline-secondary">← Back</a>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <small class="text-muted">Sales Order</small>
                <div class="fw-semibold">@(Model.SONumber ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">SO Date</small>
                <div>@(Model.SODate?.ToString("dd MMM yyyy") ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Required By</small>
                <div>@(Model.SORequiredBy?.ToString("dd MMM yyyy") ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Customer</small>
                <div>@(Model.SOCustomerName ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Machine</small>
                <div>@(Model.MachineName ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Shift</small>
                <div>@(Model.Shift ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Status</small>
                <div>
                    @{
                        var c = Model.Status switch {
                            "Created"    => "bg-secondary",
                            "InProgress" => "bg-info text-dark",
                            "Completed"  => "bg-success",
                            _            => "bg-secondary"
                        };
                    }
                    <span class="badge @c">@Model.Status</span>
                </div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Target Qty</small>
                <div class="fw-semibold">@Model.TargetQty</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Planned Start</small>
                <div>@Model.PlannedStartDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Planned End</small>
                <div>@Model.PlannedEndDate.ToString("dd MMM yyyy")</div>
            </div>
        </div>
    </div>
</div>

@if (Model.SOItems.Any())
{
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">Sales Order Items</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Description</th>
                        <th>UoM</th>
                        <th>Ordered</th>
                        <th>Dispatched</th>
                        <th>Pending</th>
                        <th>Rate</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.SOItems.Count; i++)
                    {
                        var item = Model.SOItems[i];
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@item.Description</td>
                            <td>@(item.UoMCode ?? "—")</td>
                            <td>@item.OrderedQty</td>
                            <td>@item.DispatchedQty</td>
                            <td>@item.PendingQty</td>
                            <td>@item.UnitRate.ToString("C")</td>
                            <td>@item.LineTotal.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.CustomerJobs.Any())
{
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">Customer Jobs</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Job Title</th>
                        <th>Substrate</th>
                        <th>Size</th>
                        <th>Colors</th>
                        <th>Qty</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var job in Model.CustomerJobs)
                    {
                        <tr>
                            <td>@job.JobTitle</td>
                            <td>@(job.Substrate ?? "—")</td>
                            <td>@((job.Width.HasValue && job.Length.HasValue) ? $"{job.Width.Value:0.##} × {job.Length.Value:0.##}" : "—")</td>
                            <td>@(job.ColorCount?.ToString() ?? "—")</td>
                            <td>@job.Quantity</td>
                            <td>@job.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="d-flex gap-2 mb-3">
    <a asp-action="CreateBOM" asp-route-jobCardId="@Model.Id"
       class="btn btn-sm btn-outline-info">+ Request BOM</a>
    <a asp-action="CreateWorkOrder" asp-route-jobCardId="@Model.Id"
       class="btn btn-sm btn-outline-warning">+ Create Work Order</a>

    @if (Model.Status == "Created")
    {
        <form asp-action="UpdateJobCardStatus" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="status" value="InProgress" />
            <button class="btn btn-sm btn-info text-white">→ Start Production</button>
        </form>
    }
    @if (Model.Status == "InProgress")
    {
        <form asp-action="UpdateJobCardStatus" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="status" value="Completed" />
            <button class="btn btn-sm btn-success">✓ Mark Completed</button>
        </form>
    }
</div>

@if (Model.BOMs.Any())
{
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">BOM Requests</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr><th>BOM No</th><th>Status</th><th>Items</th></tr>
                </thead>
                <tbody>
                    @foreach (var bom in Model.BOMs)
                    {
                        <tr>
                            <td class="fw-semibold">@bom.BOMNo</td>
                            <td><span class="badge bg-warning text-dark">@bom.Status</span></td>
                            <td>@bom.Items.Count items</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.BOMs.Any())
{
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">BOM Item Details</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>BOM</th>
                        <th>Item</th>
                        <th>UoM</th>
                        <th>Required</th>
                        <th>Issued</th>
                        <th>Balance</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var bom in Model.BOMs)
                {
                    foreach (var item in bom.Items)
                    {
                        <tr>
                            <td>@bom.BOMNo</td>
                            <td>@item.ItemName</td>
                            <td>@item.UoMCode</td>
                            <td>@item.RequiredQty</td>
                            <td>@item.IssuedQty</td>
                            <td>@(item.RequiredQty - item.IssuedQty)</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.WorkOrders.Any())
{
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">Work Orders</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>WO Number</th><th>Machine</th><th>Shift</th>
                        <th>Produced</th><th>Wastage</th><th>Status</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var wo in Model.WorkOrders)
                    {
                        <tr>
                            <td class="fw-semibold text-primary">@wo.WONumber</td>
                            <td>@wo.MachineName</td>
                            <td>@wo.Shift</td>
                            <td class="text-success fw-semibold">@wo.TotalProduced</td>
                            <td class="text-danger">@wo.TotalWastage</td>
                            <td><span class="badge bg-info text-dark">@wo.Status</span></td>
                            <td>
                                <a asp-action="WorkOrderDetails" asp-route-id="@wo.Id"
                                   class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>