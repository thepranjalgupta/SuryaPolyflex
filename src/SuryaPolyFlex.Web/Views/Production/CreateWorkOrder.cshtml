@model SuryaPolyFlex.Application.Features.Production.CreateWorkOrderDto
@{ ViewData["Title"] = "Create Work Order"; }

<div class="card shadow-sm mx-auto" style="max-width:500px">
    <div class="card-header bg-warning"><h5 class="mb-0">Create Work Order</h5></div>
    <div class="card-body">
        <form asp-action="CreateWorkOrder" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="JobCardId" type="hidden" />
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="MachineId" class="form-label fw-semibold">Machine</label>
                    <select asp-for="MachineId" asp-items="ViewBag.Machines" class="form-select">
                        <option value="">-- Select Machine --</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="Shift" class="form-label fw-semibold">Shift <span class="text-danger">*</span></label>
                    <select asp-for="Shift" asp-items="ViewBag.Shifts" class="form-select">
                        <option value="">-- Select Shift --</option>
                    </select>
                    <span asp-validation-for="Shift" class="text-danger small"></span>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning">Create Work Order</button>
                <a asp-action="JobCardDetails" asp-route-id="@Model.JobCardId"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />