@model SuryaPolyFlex.Application.Features.Production.WorkOrderDto
@{ ViewData["Title"] = "Work Order Details"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Work Order — @Model.WONumber</h4>
    <a asp-action="WorkOrders" class="btn btn-sm btn-outline-secondary">← Back</a>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <small class="text-muted">Job Card</small>
                <div>
                    @if (!string.IsNullOrEmpty(Model.JobCardNo))
                    {
                        <a asp-controller="Production" asp-action="JobCardDetails" asp-route-id="@Model.JobCardId">@Model.JobCardNo</a>
                    }
                    else
                    {
                        @("—")
                    }
                </div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Sales Order</small>
                <div>@(Model.SONumber ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">SO Date</small>
                <div>@(Model.SODate?.ToString("dd MMM yyyy") ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Required By</small>
                <div>@(Model.SORequiredBy?.ToString("dd MMM yyyy") ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Customer</small>
                <div>@(Model.SOCustomerName ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Machine</small>
                <div>@(Model.MachineName ?? "—")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Shift</small>
                <div>@Model.Shift</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Status</small>
                <div><span class="badge bg-info text-dark">@Model.Status</span></div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Total Produced</small>
                <div class="fw-semibold text-success">@Model.TotalProduced</div>
            </div>
        </div>
    </div>
</div>

@if (Model.Status != "Completed")
{
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">Add Production Entry</div>
        <div class="card-body">
            <form asp-action="AddProductionEntry" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="WorkOrderId" value="@Model.Id" />
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Produced Qty <span class="text-danger">*</span></label>
                        <input name="ProducedQty" class="form-control" type="number" step="0.001" min="0.001" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Wastage Qty</label>
                        <input name="WastageQty" class="form-control" type="number" step="0.001" min="0" value="0" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Wastage Reason</label>
                        <input name="WastageReason" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Downtime (mins)</label>
                        <input name="MachineDowntimeMin" class="form-control" type="number" min="0" value="0" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary mt-3">Save Entry</button>
            </form>
        </div>
    </div>
}

@if (Model.Entries.Any())
{
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">Production Entries</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr><th>Date</th><th>Produced</th><th>Wastage</th><th>Wastage Reason</th><th>Downtime (min)</th></tr>
                </thead>
                <tbody>
                    @foreach (var e in Model.Entries)
                    {
                        <tr>
                            <td class="small">@e.EntryDate.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                            <td class="text-success fw-semibold">@e.ProducedQty</td>
                            <td class="text-danger">@e.WastageQty</td>
                            <td class="small">@e.WastageReason</td>
                            <td>@e.MachineDowntimeMin</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-light fw-semibold">
                        <td>Total</td>
                        <td class="text-success">@Model.TotalProduced</td>
                        <td class="text-danger">@Model.TotalWastage</td>
                        <td colspan="2"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}

@if (Model.Status != "Completed" && Model.Entries.Any())
{
    <div class="d-flex gap-2">
        <form asp-action="UpdateWorkOrderStatus" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="status" value="Completed" />
            <button class="btn btn-success"
                    onclick="return confirm('Mark this Work Order as Completed?')">
                ✓ Complete Work Order
            </button>
        </form>
        @if (Model.Status == "Open")
        {
            <form asp-action="UpdateWorkOrderStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="status" value="Running" />
                <button class="btn btn-info text-white">→ Start</button>
            </form>
        }
    </div>
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>