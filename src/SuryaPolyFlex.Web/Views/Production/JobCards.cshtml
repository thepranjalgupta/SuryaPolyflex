@model List<SuryaPolyFlex.Application.Features.Production.JobCardDto>
@{ ViewData["Title"] = "Job Cards"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Job Cards</h4>
    <a asp-action="CreateJobCard" class="btn btn-primary btn-sm">+ New Job Card</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="get" class="d-flex gap-2 mb-3">
            <select name="status" class="form-select form-select-sm w-auto">
                <option value="">All Statuses</option>
                @foreach (var s in new[]{"Created","InProgress","OnHold","Completed","Cancelled"})
                {
                    <option value="@s" selected="@(ViewBag.Status == s)">@s</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-secondary">Filter</button>
            <a asp-action="JobCards" class="btn btn-sm btn-outline-danger">Clear</a>
        </form>

        <table class="table table-hover table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Job Card No</th><th>SO Number</th><th>Machine</th>
                    <th>Shift</th><th>Target Qty</th><th>Planned Start</th>
                    <th>Planned End</th><th>Status</th><th style="width:100px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted">No job cards found.</td></tr>
                }
                @foreach (var jc in Model)
                {
                    <tr>
                        <td class="fw-semibold text-primary">@jc.JobCardNo</td>
                        <td class="small">@jc.SONumber</td>
                        <td class="small">@jc.MachineName</td>
                        <td class="small">@jc.Shift</td>
                        <td>@jc.TargetQty</td>
                        <td class="small">@jc.PlannedStartDate.ToString("dd MMM yyyy")</td>
                        <td class="small">@jc.PlannedEndDate.ToString("dd MMM yyyy")</td>
                        <td>
                            @{
                                var c = jc.Status switch {
                                    "Created"    => "bg-secondary",
                                    "InProgress" => "bg-info text-dark",
                                    "OnHold"     => "bg-warning text-dark",
                                    "Completed"  => "bg-success",
                                    "Cancelled"  => "bg-danger",
                                    _            => "bg-secondary"
                                };
                            }
                            <span class="badge @c">@jc.Status</span>
                        </td>
                        <td>
                            <a asp-action="JobCardDetails" asp-route-id="@jc.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>