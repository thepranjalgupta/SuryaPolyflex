@{
    ViewData["Title"] = "RBAC Administration";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="fas fa-shield-alt me-2 text-primary"></i>RBAC Administration</h4>
</div>

<div class="row g-4">
    <!-- Permissions -->
    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-primary">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="fas fa-key me-2"></i>Permissions</h6>
            </div>
            <div class="card-body text-center">
                <p class="text-muted small">Manage dynamic permissions for roles. Create, view, and assign permissions to roles.</p>
                <a asp-action="Permissions" class="btn btn-sm btn-primary">
                    <i class="fas fa-list me-1"></i> View Permissions
                </a>
            </div>
        </div>
    </div>

    <!-- Role-Permission Assignment -->
    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-success">
            <div class="card-header bg-success text-white">
                <h6 class="mb-0"><i class="fas fa-users-cog me-2"></i>Role Permissions</h6>
            </div>
            <div class="card-body text-center">
                <p class="text-muted small">Assign or revoke permissions for system roles. Control what each role can access.</p>
                <a asp-action="RolePermissions" class="btn btn-sm btn-success">
                    <i class="fas fa-cogs me-1"></i> Manage Role Permissions
                </a>
            </div>
        </div>
    </div>

    <!-- Dynamic Rules -->
    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-info">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0"><i class="fas fa-gavel me-2"></i>Dynamic Rules</h6>
            </div>
            <div class="card-body text-center">
                <p class="text-muted small">Define conditional rules for permissions. Control access based on ownership, department, time, and custom conditions.</p>
                <a asp-action="Permissions" class="btn btn-sm btn-info">
                    <i class="fas fa-plus me-1"></i> Manage Permissions & Rules
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header">
                <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>RBAC/RABAC System Info</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <h6 class="fw-bold">Permission Hierarchy</h6>
                        <ul class="small text-muted">
                            <li>Permissions → Module + Action (e.g., <code>SO_VIEW</code>)</li>
                            <li>RolePermissions → Maps Role to Permission</li>
                            <li>Rules → Conditional logic on Permissions</li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h6 class="fw-bold">Rule Types</h6>
                        <ul class="small text-muted">
                            <li><strong>Ownership</strong> — User owns the record</li>
                            <li><strong>Department</strong> — User's department matches</li>
                            <li><strong>TimeBased</strong> — Access within time window</li>
                            <li><strong>Custom</strong> — JSON conditions</li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h6 class="fw-bold">Key Features</h6>
                        <ul class="small text-muted">
                            <li>Database-driven dynamic permissions</li>
                            <li>Soft-delete for all entities</li>
                            <li>Audit logging on all changes</li>
                            <li>Multi-role user support</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
