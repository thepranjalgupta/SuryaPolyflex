@model List<SuryaPolyFlex.Domain.Entities.Core.Rule>
@{
    ViewData["Title"] = "Permission Rules";
    var permissionId = ViewBag.PermissionId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="fas fa-gavel me-2 text-info"></i>Rules for Permission</h4>
    @if (permissionId.HasValue)
    {
        <a asp-action="Permission" asp-route-id="@permissionId.Value" class="btn btn-sm btn-outline-secondary">← Back</a>
    }
    else
    {
        <a asp-action="Permissions" class="btn btn-sm btn-outline-secondary">← Back to Permissions</a>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h6 class="mb-0"><i class="fas fa-plus me-2"></i>Create New Rule</h6>
    </div>
    <div class="card-body">
        <form asp-action="CreateRule" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="PermissionId" value="@permissionId" />
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Rule Name</label>
                    <input name="Name" class="form-control form-control-sm" required placeholder="e.g., Owner Only" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Scope</label>
                    <select name="Scope" class="form-select form-select-sm">
                        <option value="All">Full Access</option>
                        <option value="Owner">Own Records</option>
                        <option value="Department">Department Records</option>
                        <option value="OwnerOrDepartment" selected>Owner + Department</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <p class="small text-muted">Rules are evaluated with OR logic. Select a scope; no JSON syntax is needed.</p>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-sm btn-primary w-100">Add Rule</button>
                </div>
            </div>
            <div class="mt-2">
                <label class="form-label fw-semibold">Description</label>
                <input name="Description" class="form-control form-control-sm" placeholder="Optional description..." />
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        <h6 class="mb-0"><i class="fas fa-list me-2"></i>Existing Rules</h6>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="text-muted text-center">No rules defined for this permission.</p>
        }
        <table class="table table-hover table-sm align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Name</th>
                    <th>Scope</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th style="width:80px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rule in Model)
                {
                    <tr>
                        <td class="fw-semibold">@rule.Name</td>
                        <td><span class="badge bg-info">@rule.Scope</span></td>
                        <td class="small text-muted">@rule.Description</td>
                        <td>
                            @if (!rule.IsDeleted)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Deleted</span>
                            }
                        </td>                        <td>
                            <form asp-action="DeleteRule" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this rule?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@rule.Id" />
                                <button class="btn btn-xs btn-outline-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
