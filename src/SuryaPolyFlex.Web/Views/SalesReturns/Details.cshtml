@model SuryaPolyFlex.Application.Features.SalesOrders.SalesReturnDto
@{ ViewData["Title"] = "Sales Return Details"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Sales Return — @Model.ReturnNo</h4>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
</div>

@if (TempData["Success"] != null)
{ <div class="alert alert-success">@TempData["Success"]</div> }
@if (TempData["Error"] != null)
{ <div class="alert alert-danger">@TempData["Error"]</div> }

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <small class="text-muted">Sales Order</small>
                <div class="fw-semibold">@Model.SONumber</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Customer</small>
                <div>@Model.CustomerName</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Return Date</small>
                <div>@Model.ReturnDate.ToLocalTime().ToString("dd MMM yyyy")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Status</small>
                <div><span class="badge bg-warning text-dark">@Model.Status</span></div>
            </div>
            <div class="col-12">
                <small class="text-muted">Reason</small>
                <div>@Model.Reason</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body p-0">
        <table class="table table-sm mb-0">
            <thead class="table-light">
                <tr><th>#</th><th>Description</th><th>Qty</th><th>Rate</th><th>Total</th><th>Reason</th></tr>
            </thead>
            <tbody>
                @{ int sr = 1; }
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@sr++</td>
                        <td>@item.Description</td>
                        <td>@item.ReturnQty</td>
                        <td>₹@item.UnitRate</td>
                        <td>₹@item.LineTotal.ToString("N2")</td>
                        <td class="small text-muted">@item.ReturnReason</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-light fw-semibold">
                    <td colspan="4" class="text-end">Total</td>
                    <td>₹@Model.TotalReturnValue.ToString("N2")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@if (Model.Status == "Pending")
{
    <div class="card shadow-sm">
        <div class="card-header fw-semibold">Approve & Restock</div>
        <div class="card-body">
            <form asp-action="Approve" method="post" class="d-flex gap-3 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div>
                    <label class="form-label fw-semibold">Restock to Warehouse</label>
                    <select name="warehouseId" asp-items="ViewBag.Warehouses"
                            class="form-select" required>
                        <option value="">-- Select Warehouse --</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-success"
                        onclick="return confirm('Approve and update stock?')">
                    ✓ Approve Return
                </button>
            </form>
        </div>
    </div>
}