@model List<SuryaPolyFlex.Application.Features.MaterialIssue.MaterialIssueDto>
@{ ViewData["Title"] = "Material Issues"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Material Issues</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ New Issue</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover table-sm">
            <thead class="table-dark">
                <tr><th>Issue No</th><th>Date</th><th>Warehouse</th><th>Remarks</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted">No material issues found.</td></tr>
                }
                @foreach (var m in Model)
                {
                    <tr>
                        <td class="fw-semibold text-primary">@m.IssueNo</td>
                        <td class="small">@m.IssueDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>@m.WarehouseName</td>
                        <td class="small text-muted">@m.Remarks</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@m.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>