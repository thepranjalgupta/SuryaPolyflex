@model SuryaPolyFlex.Application.Features.MaterialIssue.MaterialIssueDto
@{ ViewData["Title"] = "Material Issue Details"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Material Issue — @Model.IssueNo</h4>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body row g-2">
        <div class="col-md-3"><small class="text-muted">Issue Date</small><div>@Model.IssueDate.ToString("dd MMM yyyy")</div></div>
        <div class="col-md-3"><small class="text-muted">Warehouse</small><div>@Model.WarehouseName</div></div>
        <div class="col-md-3"><small class="text-muted">Department</small><div>@(Model.DepartmentName ?? "—")</div></div>
        <div class="col-md-3"><small class="text-muted">Remarks</small><div>@(Model.Remarks ?? "—")</div></div>
    </div>
</div>

@if (Model.Items.Any())
{
    <div class="card shadow-sm">
        <div class="card-header fw-semibold">Material Items</div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light"><tr><th>#</th><th>Item</th><th>UoM</th><th>Requested</th><th>Issued</th></tr></thead>
                <tbody>
                    @for (var i = 0; i < Model.Items.Count; i++)
                    {
                        var item = Model.Items[i];
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@item.ItemCode - @item.ItemName</td>
                            <td>@(item.UoMCode ?? "—")</td>
                            <td>@item.RequestedQty</td>
                            <td>@item.IssuedQty</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">No material issue lines found.</div>
}
