@model SuryaPolyFlex.Application.Features.MaterialIssue.CreateMaterialIssueDto
@{
    ViewData["Title"] = "New Material Issue";
    var itemsList = ViewBag.Items as List<SuryaPolyFlex.Application.Features.Items.ItemSelectDto>
                    ?? new List<SuryaPolyFlex.Application.Features.Items.ItemSelectDto>();
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white"><h5 class="mb-0">New Material Issue</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post" id="issueForm">
            @Html.AntiForgeryToken()
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="FromWarehouseId" class="form-label fw-semibold">From Warehouse <span class="text-danger">*</span></label>
                    <select asp-for="FromWarehouseId" asp-items="ViewBag.Warehouses" class="form-select">
                        <option value="">-- Select --</option>
                    </select>
                </div>
                <div class="col-md-8">
                    <label asp-for="Remarks" class="form-label fw-semibold">Remarks</label>
                    <input asp-for="Remarks" class="form-control" />
                </div>
            </div>

            <h6 class="fw-semibold mb-2">Items <span class="text-danger">*</span></h6>
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Item</th>
                        <th style="width:140px">Requested Qty</th>
                        <th style="width:140px">Issued Qty</th>
                        <th style="width:50px"></th>
                    </tr>
                </thead>
                <tbody id="issueBody"></tbody>
            </table>

            <div id="noIssueMsg" class="text-muted small mb-2">No items added.</div>
            <button type="button" class="btn btn-sm btn-outline-primary mb-3"
                    onclick="addIssueRow()">+ Add Item</button>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create Issue</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    const items = [
        @foreach (var item in itemsList)
        {
            @Html.Raw($"{{ id: {item.Id}, code: '{item.ItemCode}', name: '{item.Name.Replace("'", "\\'")}', uom: '{item.UoMCode}' }},")
        }
    ];
    let issueIndex = 0;

    function addIssueRow() {
        document.getElementById('noIssueMsg').style.display = 'none';
        const tbody = document.getElementById('issueBody');
        const tr    = document.createElement('tr');
        tr.innerHTML = `
            <td>
                <select name="Items[${issueIndex}].ItemId"
                        class="form-select form-select-sm" required>
                    <option value="">-- Select Item --</option>
                    ${items.map(i => `<option value="${i.id}">${i.code} - ${i.name} (${i.uom})</option>`).join('')}
                </select>
            </td>
            <td>
                <input type="number" name="Items[${issueIndex}].RequestedQty"
                       class="form-control form-control-sm"
                       step="0.001" min="0.001" required />
            </td>
            <td>
                <input type="number" name="Items[${issueIndex}].IssuedQty"
                       class="form-control form-control-sm"
                       step="0.001" min="0.001" required />
            </td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger"
                        onclick="this.closest('tr').remove(); reindexIssue()">✕</button>
            </td>`;
        tbody.appendChild(tr);
        issueIndex++;
        reindexIssue();
    }

    function reindexIssue() {
        document.getElementById('issueBody').querySelectorAll('tr').forEach((row, i) => {
            row.querySelectorAll('[name]').forEach(el => {
                el.name = el.name.replace(/Items\[\d+\]/, `Items[${i}]`);
            });
        });
        issueIndex = document.getElementById('issueBody').querySelectorAll('tr').length;
    }
</script>