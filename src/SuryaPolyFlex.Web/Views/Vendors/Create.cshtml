@model SuryaPolyFlex.Application.Features.Vendors.CreateVendorDto
@{ ViewData["Title"] = "Add Vendor"; }

<div class="card shadow-sm mx-auto" style="max-width:700px">
    <div class="card-header bg-primary text-white"><h5 class="mb-0">Add Vendor</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <h6 class="text-muted mb-3">Basic Info</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="VendorCode" class="form-label fw-semibold">Code <span class="text-danger">*</span></label>
                    <input asp-for="VendorCode" class="form-control" placeholder="e.g. VND001" />
                    <span asp-validation-for="VendorCode" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Name" class="form-label fw-semibold">Vendor Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ContactPerson" class="form-label fw-semibold">Contact Person</label>
                    <input asp-for="ContactPerson" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Mobile" class="form-label fw-semibold">Mobile</label>
                    <input asp-for="Mobile" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Email" class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="City" class="form-label fw-semibold">City</label>
                    <input asp-for="City" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="State" class="form-label fw-semibold">State</label>
                    <input asp-for="State" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="PinCode" class="form-label fw-semibold">Pin Code</label>
                    <input asp-for="PinCode" class="form-control" />
                </div>
            </div>

            <h6 class="text-muted mt-4 mb-3">Tax & Banking</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="GSTIN" class="form-label fw-semibold">GSTIN</label>
                    <input asp-for="GSTIN" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="PAN" class="form-label fw-semibold">PAN</label>
                    <input asp-for="PAN" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="PaymentTermDays" class="form-label fw-semibold">Payment Term (Days)</label>
                    <input asp-for="PaymentTermDays" class="form-control" type="number" />
                </div>
                <div class="col-md-4">
                    <label asp-for="BankName" class="form-label fw-semibold">Bank Name</label>
                    <input asp-for="BankName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="BankAccount" class="form-label fw-semibold">Account No</label>
                    <input asp-for="BankAccount" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="BankIFSC" class="form-label fw-semibold">IFSC Code</label>
                    <input asp-for="BankIFSC" class="form-control" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save Vendor</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />