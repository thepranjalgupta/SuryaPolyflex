@model List<SuryaPolyFlex.Application.Features.Indents.IndentDto>
@{ ViewData["Title"] = "Indents"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Indent Requests</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ New Indent</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="get" class="d-flex gap-2 mb-3">
            <select name="status" class="form-select form-select-sm w-auto">
                <option value="">All Statuses</option>
                <option value="Draft" selected="@(ViewBag.Status == "Draft")">Draft</option>
                <option value="PendingApproval" selected="@(ViewBag.Status == "PendingApproval")">Pending Approval</option>
                <option value="Approved" selected="@(ViewBag.Status == "Approved")">Approved</option>
                <option value="Rejected" selected="@(ViewBag.Status == "Rejected")">Rejected</option>
                <option value="POGenerated" selected="@(ViewBag.Status == "POGenerated")">PO Generated</option>
            </select>
            <button class="btn btn-sm btn-outline-secondary">Filter</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-danger">Clear</a>
        </form>

        <table class="table table-hover table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Indent No</th><th>Date</th><th>Department</th>
                    <th>Requested By</th><th>Items</th><th>Status</th><th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted">No indents found.</td></tr>
                }
                @foreach (var i in Model)
                {
                    <tr>
                        <td class="fw-semibold text-primary">@i.IndentNumber</td>
                        <td class="small">@i.IndentDate.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td class="small">@i.DepartmentName</td>
                        <td class="small">@i.RequestedByName</td>
                        <td><span class="badge bg-secondary">@i.Items.Count items</span></td>
                        <td>
                            @{
                                var badgeColor = i.Status switch {
                                    "Draft"          => "bg-secondary",
                                    "PendingApproval"=> "bg-warning text-dark",
                                    "Approved"       => "bg-success",
                                    "Rejected"       => "bg-danger",
                                    "POGenerated"    => "bg-info text-dark",
                                    _                => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeColor">@i.Status</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@i.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                            @if (i.Status == "PendingApproval")
                            {
                                <a asp-action="Approve" asp-route-id="@i.Id"
                                   class="btn btn-sm btn-outline-success">Approve</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>