@model SuryaPolyFlex.Application.Features.Indents.IndentDto
@{ ViewData["Title"] = "Approve Indent"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Approve Indent — @Model.IndentNumber</h4>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Approve" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="IndentId" value="@Model.Id" />

            <table class="table table-sm table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th><th>Item</th><th>UoM</th>
                        <th>Requested Qty</th><th>Approved Qty</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int sr = 0; }
                    @foreach (var item in Model.Items)
                    {
                        <input type="hidden"
                               name="Items[@sr].IndentItemId" value="@item.Id" />
                        <tr>
                            <td>@(sr + 1)</td>
                            <td>@item.ItemCode — @item.ItemName</td>
                            <td>@item.UoMCode</td>
                            <td class="fw-semibold">@item.RequestedQty</td>
                            <td>
                                <input type="number"
                                       name="Items[@sr].ApprovedQty"
                                       value="@item.RequestedQty"
                                       class="form-control form-control-sm"
                                       style="width:120px"
                                       step="0.001" min="0" />
                            </td>
                        </tr>
                        sr++;
                    }
                </tbody>
            </table>

            <div class="mb-3">
                <label class="form-label fw-semibold">Remarks</label>
                <textarea name="Remarks" class="form-control" rows="2"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" name="Action" value="Approve"
                        class="btn btn-success">✓ Approve</button>
                <button type="submit" name="Action" value="Reject"
                        class="btn btn-danger">✕ Reject</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>