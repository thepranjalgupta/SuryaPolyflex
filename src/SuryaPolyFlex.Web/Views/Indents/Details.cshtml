@model SuryaPolyFlex.Application.Features.Indents.IndentDto
@{ ViewData["Title"] = "Indent Details"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Indent — @Model.IndentNumber</h4>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Back</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <small class="text-muted">Date</small>
                <div class="fw-semibold">@Model.IndentDate.ToLocalTime().ToString("dd MMM yyyy")</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Department</small>
                <div class="fw-semibold">@Model.DepartmentName</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Requested By</small>
                <div class="fw-semibold">@Model.RequestedByName</div>
            </div>
            <div class="col-md-3">
                <small class="text-muted">Status</small>
                <div>
                    @{
                        var color = Model.Status switch {
                            "Draft"           => "bg-secondary",
                            "PendingApproval" => "bg-warning text-dark",
                            "Approved"        => "bg-success",
                            "Rejected"        => "bg-danger",
                            _                 => "bg-secondary"
                        };
                    }
                    <span class="badge @color">@Model.Status</span>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Remarks))
            {
                <div class="col-12">
                    <small class="text-muted">Remarks</small>
                    <div>@Model.Remarks</div>
                </div>
            }
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header fw-semibold">Items</div>
    <div class="card-body p-0">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th><th>Item Code</th><th>Item Name</th>
                    <th>UoM</th><th>Requested Qty</th><th>Approved Qty</th><th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                @{int sr = 1;}
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@sr++</td>
                        <td><span class="badge bg-secondary">@item.ItemCode</span></td>
                        <td>@item.ItemName</td>
                        <td>@item.UoMCode</td>
                        <td>@item.RequestedQty</td>
                        <td>
                            @if (item.ApprovedQty > 0)
                            {
                                <span class="text-success fw-semibold">@item.ApprovedQty</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="small text-muted">@item.Remarks</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex gap-2 mt-3">
    @if (Model.Status == "Draft")
    {
        <form asp-action="Submit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button class="btn btn-warning"
                    onclick="return confirm('Submit this indent for approval?')">
                ➤ Submit for Approval
            </button>
        </form>
    }

    @if (Model.Status == "PendingApproval")
    {
        <a asp-action="Approve" asp-route-id="@Model.Id"
           class="btn btn-success">✓ Approve / Reject</a>
    }

    <a asp-action="Index" class="btn btn-outline-secondary">← Back to List</a>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>