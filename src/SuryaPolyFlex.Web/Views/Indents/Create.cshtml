@model SuryaPolyFlex.Application.Features.Indents.CreateIndentDto
@{
    ViewData["Title"] = "New Indent";
    var itemsList = ViewBag.Items as List<SuryaPolyFlex.Application.Features.Items.ItemSelectDto>
                    ?? new List<SuryaPolyFlex.Application.Features.Items.ItemSelectDto>();
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">New Indent Request</h5>
    </div>
    <div class="card-body">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Create" method="post" id="indentForm">
            @Html.AntiForgeryToken()

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="DepartmentId" class="form-label fw-semibold">
                        Department <span class="text-danger">*</span>
                    </label>
                    <select asp-for="DepartmentId"
                            asp-items="ViewBag.Departments"
                            class="form-select">
                        <option value="">-- Select Department --</option>
                    </select>
                    <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Remarks" class="form-label fw-semibold">Remarks</label>
                    <input asp-for="Remarks" class="form-control" />
                </div>
            </div>

            <h6 class="fw-semibold mb-2">Items <span class="text-danger">*</span></h6>

            <table class="table table-sm table-bordered" id="itemsTable">
                <thead class="table-light">
                    <tr>
                        <th>Item</th>
                        <th style="width:160px">Requested Qty</th>
                        <th style="width:200px">Remarks</th>
                        <th style="width:50px"></th>
                    </tr>
                </thead>
                <tbody id="itemsBody"></tbody>
            </table>

            <div id="noItemsMsg" class="text-muted small mb-2">
                No items added yet. Click "+ Add Item" below.
            </div>

            <button type="button"
                    class="btn btn-sm btn-outline-primary mb-3"
                    onclick="addItemRow()">
                + Add Item
            </button>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn btn-primary">Save as Draft</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // Build items array from Razor — PascalCase matches C# serialization
    const items = [
        @foreach (var item in itemsList)
        {
            @Html.Raw($"{{ id: {item.Id}, code: '{item.ItemCode}', name: '{item.Name.Replace("'", "\\'")}', uom: '{item.UoMCode}' }},")
        }
    ];

    let rowIndex = 0;

    function buildOptions() {
        let html = '<option value="">-- Select Item --</option>';
        items.forEach(i => {
            html += `<option value="${i.id}">${i.code} - ${i.name} (${i.uom})</option>`;
        });
        return html;
    }

    function addItemRow() {
        document.getElementById('noItemsMsg').style.display = 'none';
        const tbody = document.getElementById('itemsBody');
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>
                <select name="Items[${rowIndex}].ItemId"
                        class="form-select form-select-sm" required>
                    ${buildOptions()}
                </select>
            </td>
            <td>
                <input type="number"
                       name="Items[${rowIndex}].RequestedQty"
                       class="form-control form-control-sm"
                       step="0.001" min="0.001" required />
            </td>
            <td>
                <input type="text"
                       name="Items[${rowIndex}].Remarks"
                       class="form-control form-control-sm" />
            </td>
            <td class="text-center">
                <button type="button"
                        class="btn btn-sm btn-outline-danger"
                        onclick="removeRow(this)">✕</button>
            </td>`;
        tbody.appendChild(tr);
        rowIndex++;
        updateRowIndexes();
    }

    function removeRow(btn) {
        btn.closest('tr').remove();
        updateRowIndexes();
        if (document.getElementById('itemsBody').children.length === 0) {
            document.getElementById('noItemsMsg').style.display = 'block';
        }
    }

    function updateRowIndexes() {
        const rows = document.getElementById('itemsBody').querySelectorAll('tr');
        rows.forEach((row, index) => {
            row.querySelectorAll('[name]').forEach(el => {
                el.name = el.name.replace(/Items\[\d+\]/, `Items[${index}]`);
            });
        });
        rowIndex = rows.length;
    }

    // Validate at least one item before submit
    document.getElementById('indentForm').addEventListener('submit', function (e) {
        const rows = document.getElementById('itemsBody').querySelectorAll('tr');
        if (rows.length === 0) {
            e.preventDefault();
            alert('Please add at least one item before saving.');
        }
    });
</script>