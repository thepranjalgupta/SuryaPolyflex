@model List<SuryaPolyFlex.Application.Features.Departments.DepartmentDto>
@{ ViewData["Title"] = "Departments"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Departments</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Add Department</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="get" class="d-flex gap-2 mb-3">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control form-control-sm w-25"
                   placeholder="Search by name or code..." />
            <button class="btn btn-sm btn-outline-secondary">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-danger">Clear</a>
            }
        </form>

        <table class="table table-hover table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th style="width:120px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted">No departments found.</td></tr>
                }
                @foreach (var d in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@d.Code</span></td>
                        <td>@d.Name</td>
                        <td class="text-muted small">@d.Description</td>
                        <td>
                            @if (d.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td class="small text-muted">@d.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@d.Id"
                               class="btn btn-xs btn-outline-primary btn-sm">Edit</a>
                            <form asp-action="Delete" asp-route-id="@d.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this department?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-xs btn-outline-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>