@model List<SuryaPolyFlex.Application.Features.PurchaseOrders.PurchaseOrderDto>
@{ ViewData["Title"] = "Purchase Orders"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Purchase Orders</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ New PO</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="get" class="d-flex gap-2 mb-3">
            <select name="status" class="form-select form-select-sm w-auto">
                <option value="">All Statuses</option>
                <option value="Open" selected="@(ViewBag.Status == "Open")">Open</option>
                <option value="PartialReceived" selected="@(ViewBag.Status == "PartialReceived")">Partial Received</option>
                <option value="Closed" selected="@(ViewBag.Status == "Closed")">Closed</option>
                <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Cancelled</option>
            </select>
            <button class="btn btn-sm btn-outline-secondary">Filter</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-danger">Clear</a>
        </form>

        <table class="table table-hover table-sm align-middle">
            <thead class="table-dark">
                <tr>
                    <th>PO Number</th><th>Date</th><th>Vendor</th>
                    <th>Indent Ref</th><th>Amount</th><th>Status</th>
                    <th style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted">No purchase orders found.</td></tr>
                }
                @foreach (var po in Model)
                {
                    <tr>
                        <td class="fw-semibold text-primary">@po.PONumber</td>
                        <td class="small">@po.PODate.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>@po.VendorName</td>
                        <td class="small text-muted">@po.IndentNumber</td>
                        <td>₹@po.TotalAmount.ToString("N2")</td>
                        <td>
                            @{
                                var c = po.Status switch {
                                    "Open"            => "bg-primary",
                                    "PartialReceived" => "bg-warning text-dark",
                                    "Closed"          => "bg-success",
                                    "Cancelled"       => "bg-danger",
                                    _                 => "bg-secondary"
                                };
                            }
                            <span class="badge @c">@po.Status</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@po.Id"
                               class="btn btn-sm btn-outline-primary">View</a>
                            @if (po.Status == "Open")
                            {
                                <a asp-controller="GRN" asp-action="Create"
                                   asp-route-poId="@po.Id"
                                   class="btn btn-sm btn-outline-success">GRN</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>