@model SuryaPolyFlex.Application.Features.PurchaseOrders.CreatePODto
@{
    ViewData["Title"] = "New Purchase Order";
    var itemsList = ViewBag.Items as List<SuryaPolyFlex.Application.Features.Items.ItemSelectDto>
                    ?? new List<SuryaPolyFlex.Application.Features.Items.ItemSelectDto>();
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">New Purchase Order</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" id="poForm">
            @Html.AntiForgeryToken()

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <label asp-for="VendorId" class="form-label fw-semibold">Vendor <span class="text-danger">*</span></label>
                    <select asp-for="VendorId" asp-items="ViewBag.Vendors" class="form-select">
                        <option value="">-- Select Vendor --</option>
                    </select>
                    <span asp-validation-for="VendorId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="IndentId" class="form-label fw-semibold">Indent (Optional)</label>
                    <select id="indentSelect" asp-for="IndentId" asp-items="ViewBag.Indents" class="form-select">
                        <option value="">-- Select Indent --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="ExpectedDeliveryDate" class="form-label fw-semibold">Expected Delivery</label>
                    <input asp-for="ExpectedDeliveryDate" class="form-control" type="date" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Terms" class="form-label fw-semibold">Payment Terms</label>
                    <input asp-for="Terms" class="form-control" placeholder="e.g. Net 30" />
                </div>
                <div class="col-12">
                    <label asp-for="Remarks" class="form-label fw-semibold">Remarks</label>
                    <input asp-for="Remarks" class="form-control" />
                </div>
            </div>

            <h6 class="fw-semibold mb-2">Items <span class="text-danger">*</span></h6>
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Item</th>
                        <th style="width:120px">Qty</th>
                        <th style="width:130px">Unit Price (₹)</th>
                        <th style="width:100px">Tax %</th>
                        <th style="width:120px">Line Total</th>
                        <th style="width:50px"></th>
                    </tr>
                </thead>
                <tbody id="poItemsBody">
                    @if (Model.Items != null)
                    {
                        int index = 0;
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <select name="Items[@index].ItemId" class="form-select item-select">
                                        <option value="">-- Select Item --</option>
                                        @foreach (var it in itemsList)
                                        {
                                            <option value="@it.Id" selected="@(it.Id == item.ItemId)">@it.ItemCode - @it.Name (@it.UoMCode)</option>
                                        }
                                    </select>
                                </td>
                                <td><input name="Items[@index].OrderedQty" type="number" step="0.01" class="form-control qty-input" value="@item.OrderedQty.ToString("0.00")" /></td>
                                <td><input name="Items[@index].UnitPrice" type="number" step="0.01" class="form-control price-input" value="@item.UnitPrice.ToString("0.00")" /></td>
                                <td><input name="Items[@index].TaxPct" type="number" step="0.01" class="form-control tax-input" value="@item.TaxPct.ToString("0.00")" /></td>
                                <td class="line-total">₹@((item.OrderedQty * item.UnitPrice).ToString("0.00"))</td>
                                <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(this)">×</button></td>
                            </tr>
                            index++;
                        }
                    }
                </tbody>
            </table>

            <div id="noItemsMsg" class="text-muted small mb-2" style="display: @(Model.Items != null && Model.Items.Any() ? "none" : "block")">No items added yet.</div>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <button type="button" class="btn btn-sm btn-outline-primary"
                        onclick="addPOItemRow()">+ Add Item</button>
                <div class="fw-semibold">
                    Total: ₹<span id="grandTotal">0.00</span>
                </div>
            </div>

            <input type="hidden" name="TotalAmount" id="totalAmountField" value="0" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create PO</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    const items = [
        @foreach (var item in itemsList)
        {
            @Html.Raw($"{{ id: {item.Id}, code: '{item.ItemCode}', name: '{item.Name.Replace("'", "\\'")}', uom: '{item.UoMCode}' }},")
        }
    ];

    let rowIndex = @(Model.Items?.Count ?? 0);

    function buildOptions() {
        let html = '<option value="">-- Select Item --</option>';
        items.forEach(i => {
            html += `<option value="${i.id}">${i.code} - ${i.name} (${i.uom})</option>`;
        });
        return html;
    }

    function addPOItemRow() {
        document.getElementById('noItemsMsg').style.display = 'none';
        const tbody = document.getElementById('poItemsBody');
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>
                <select name="Items[${rowIndex}].ItemId"
                        class="form-select form-select-sm" required>
                    ${buildOptions()}
                </select>
            </td>
            <td>
                <input type="number" name="Items[${rowIndex}].OrderedQty"
                       class="form-control form-control-sm qty-input"
                       step="0.001" min="0.001" value="1" required
                       oninput="updateTotal()" />
            </td>
            <td>
                <input type="number" name="Items[${rowIndex}].UnitPrice"
                       class="form-control form-control-sm price-input"
                       step="0.01" min="0.01" value="0" required
                       oninput="updateTotal()" />
            </td>
            <td>
                <input type="number" name="Items[${rowIndex}].TaxPct"
                       class="form-control form-control-sm"
                       step="0.01" min="0" max="100" value="0" />
            </td>
            <td class="line-total text-end fw-semibold">₹0.00</td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger"
                        onclick="removeRow(this)">✕</button>
            </td>`;
        tbody.appendChild(tr);
        rowIndex++;
        updateRowIndexes();
    }

    function removeRow(btn) {
        btn.closest('tr').remove();
        updateRowIndexes();
        updateTotal();
        if (document.getElementById('poItemsBody').children.length === 0)
            document.getElementById('noItemsMsg').style.display = 'block';
    }

    function updateRowIndexes() {
        const rows = document.getElementById('poItemsBody').querySelectorAll('tr');
        rows.forEach((row, index) => {
            row.querySelectorAll('[name]').forEach(el => {
                el.name = el.name.replace(/Items\[\d+\]/, `Items[${index}]`);
            });
        });
        rowIndex = rows.length;
    }

    function updateTotal() {
        let grand = 0;
        document.getElementById('poItemsBody').querySelectorAll('tr').forEach(row => {
            const qty   = parseFloat(row.querySelector('.qty-input')?.value)   || 0;
            const price = parseFloat(row.querySelector('.price-input')?.value) || 0;
            const line  = qty * price;
            const ltCell = row.querySelector('.line-total');
            if (ltCell) ltCell.textContent = '₹' + line.toFixed(2);
            grand += line;
        });
        document.getElementById('grandTotal').textContent    = grand.toFixed(2);
        document.getElementById('totalAmountField').value    = grand.toFixed(2);
    }

    document.getElementById('poForm').addEventListener('submit', function(e) {
        if (document.getElementById('poItemsBody').children.length === 0) {
            e.preventDefault();
            alert('Please add at least one item.');
        }
    });

    document.addEventListener('DOMContentLoaded', () => {
        updateTotal();
        
        // Indent auto-load handler
        const indentSelect = document.getElementById('indentSelect');
        if (indentSelect) {
            indentSelect.addEventListener('change', function() {
                const val = this.value;
                if (!val) return;
                // Reload page with selected indent ID to auto-populate items in GET
                window.location.href = '@Url.Action("Create", "PurchaseOrders")?indentId=' + encodeURIComponent(val);
            });
        }
    });
</script>