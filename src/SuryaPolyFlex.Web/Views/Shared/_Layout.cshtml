<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SuryaPolyFlex ERP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root { 
            --sidebar-width: 260px; 
            --topbar-height: 60px; 
            --primary-bg: #1e293b; /* Modern Slate 800 */
            --primary-dark: #0f172a; /* Slate 900 */
            --active-color: #3b82f6; /* Blue 500 */
        }
        body { 
            background: #f4f6f9; 
            font-size: 14px; 
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        /* --- Sidebar Base --- */
        #sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--primary-bg);
            position: fixed;
            top: 0; left: 0;
            z-index: 1000;
            overflow-y: auto;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
        }

        /* --- Sidebar Scrollbar --- */
        #sidebar::-webkit-scrollbar { width: 6px; }
        #sidebar::-webkit-scrollbar-track { background: transparent; }
        #sidebar::-webkit-scrollbar-thumb { 
            background: rgba(255, 255, 255, 0.15); 
            border-radius: 10px; 
        }
        #sidebar:hover::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.25); }

        /* --- Sidebar Items --- */
        #sidebar .sidebar-brand {
            padding: 18px 20px;
            background: var(--primary-dark);
            color: #fff;
            font-weight: 700;
            font-size: 16px;
            letter-spacing: 0.5px;
            position: sticky; /* Keeps brand at top while scrolling */
            top: 0;
            z-index: 10;
        }
        #sidebar .nav-section {
            padding: 24px 20px 8px;
            font-size: 11px;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 1.2px;
        }
        #sidebar .nav-link {
            color: #cbd5e1;
            padding: 10px 16px;
            margin: 4px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 13.5px;
            font-weight: 500;
            transition: all 0.2s ease;
            border-radius: 6px;
            text-decoration: none;
        }
        #sidebar .nav-link:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.06);
            transform: translateX(3px); /* Subtle slide effect */
        }
        #sidebar .nav-link.active {
            color: #fff;
            background: var(--active-color);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
            transform: translateX(0);
        }
        #sidebar .nav-link i { 
            width: 20px; 
            text-align: center; 
            font-size: 15px; 
            opacity: 0.8;
        }
        #sidebar .nav-link.active i {
            opacity: 1;
        }

        /* --- Topbar --- */
        #topbar {
            height: var(--topbar-height);
            background: #fff;
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            z-index: 999;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            padding: 0 24px;
            gap: 16px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.02);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        #topbar .page-title {
            font-weight: 600;
            font-size: 16px;
            color: #1e293b;
        }
        #topbar .ms-auto { margin-left: auto; }

        /* --- Main content --- */
        #main-content {
            margin-left: var(--sidebar-width);
            margin-top: var(--topbar-height);
            padding: 28px;
            min-height: calc(100vh - var(--topbar-height));
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* --- Badges & misc --- */
        .badge { font-size: 11px; padding: 0.4em 0.6em; }
        .table > :not(caption) > * > * { padding: 12px 16px; vertical-align: middle; }

        /* --- Mobile Responsiveness --- */
        @@media (max-width: 768px) {
            #sidebar { left: calc(-1 * var(--sidebar-width)); }
            #sidebar.open { left: 0; }
            #topbar, #main-content { margin-left: 0; }
        }
    </style>
</head>
<body>

<nav id="sidebar">
    <div class="sidebar-brand">
        <i class="fas fa-industry me-2 text-primary text-opacity-75"></i>SuryaPolyFlex ERP
    </div>

    <div class="nav-section">Main</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
       asp-controller="Dashboard" asp-action="Index">
        <i class="fas fa-tachometer-alt"></i> Dashboard
    </a>

    <div class="nav-section">Masters</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Departments" ? "active" : "")"
       asp-controller="Departments" asp-action="Index">
        <i class="fas fa-sitemap"></i> Departments
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Employees" ? "active" : "")"
       asp-controller="Employees" asp-action="Index">
        <i class="fas fa-users"></i> Employees
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
       asp-controller="Users" asp-action="Index">
        <i class="fas fa-user-shield"></i> Users
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vendors" ? "active" : "")"
       asp-controller="Vendors" asp-action="Index">
        <i class="fas fa-truck"></i> Vendors
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ? "active" : "")"
       asp-controller="Customers" asp-action="Index">
        <i class="fas fa-building"></i> Customers
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Items" ? "active" : "")"
       asp-controller="Items" asp-action="Index">
        <i class="fas fa-boxes"></i> Items
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Warehouses" ? "active" : "")"
       asp-controller="Warehouses" asp-action="Index">
        <i class="fas fa-warehouse"></i> Warehouses
    </a>

    <div class="nav-section">Procurement</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Indents" ? "active" : "")"
       asp-controller="Indents" asp-action="Index">
        <i class="fas fa-file-alt"></i> Indents
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PurchaseOrders" ? "active" : "")"
       asp-controller="PurchaseOrders" asp-action="Index">
        <i class="fas fa-shopping-cart"></i> Purchase Orders
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "GRN" ? "active" : "")"
       asp-controller="GRN" asp-action="Index">
        <i class="fas fa-clipboard-check"></i> GRN
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "MaterialIssue" ? "active" : "")"
       asp-controller="MaterialIssue" asp-action="Index">
        <i class="fas fa-dolly"></i> Material Issue
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "GateEntry" ? "active" : "")"
   asp-controller="GateEntry" asp-action="Index">
    <i class="fas fa-door-open"></i> Gate Entry
</a>

    <div class="nav-section">Sales</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Leads" ? "active" : "")"
       asp-controller="Leads" asp-action="Index">
        <i class="fas fa-funnel-dollar"></i> Leads
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Quotations" ? "active" : "")"
       asp-controller="Quotations" asp-action="Index">
        <i class="fas fa-file-invoice"></i> Quotations
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SalesOrders" ? "active" : "")"
       asp-controller="SalesOrders" asp-action="Index">
        <i class="fas fa-receipt"></i> Sales Orders
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SalesReturns" ? "active" : "")"
   asp-controller="SalesReturns" asp-action="Index">
    <i class="fas fa-undo"></i> Sales Returns
</a>

    <div class="nav-section">Production</div>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "JobCards" ? "active" : "")"
       asp-controller="Production" asp-action="JobCards">
        <i class="fas fa-tasks"></i> Job Cards
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "WorkOrders" ? "active" : "")"
       asp-controller="Production" asp-action="WorkOrders">
        <i class="fas fa-cogs"></i> Work Orders
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Machines" ? "active" : "")"
       asp-controller="Production" asp-action="Machines">
        <i class="fas fa-industry"></i> Machines
    </a>

    <div class="nav-section">Dispatch</div>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Challans" ? "active" : "")"
       asp-controller="Dispatch" asp-action="Challans">
        <i class="fas fa-shipping-fast"></i> Delivery Challans
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Transporters" ? "active" : "")"
       asp-controller="Dispatch" asp-action="Transporters">
        <i class="fas fa-truck-moving"></i> Transporters
    </a>

    <div class="nav-section">Inventory</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Stock" && ViewContext.RouteData.Values["action"]?.ToString() == "Balance" ? "active" : "")"
   asp-controller="Stock" asp-action="Balance">
    <i class="fas fa-chart-bar"></i> Stock Balance
</a>
<a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Stock" && ViewContext.RouteData.Values["action"]?.ToString() == "Ledger" ? "active" : "")"
   asp-controller="Stock" asp-action="Ledger">
    <i class="fas fa-list"></i> Stock Ledger
</a>

    <div class="nav-section mt-3">Account</div>
    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline pb-4 d-block">
        @Html.AntiForgeryToken()
        <button type="submit" class="nav-link border-0 bg-transparent w-100 text-start">
            <i class="fas fa-sign-out-alt"></i> Logout
        </button>
    </form>
</nav>

<div id="topbar">
    <button class="btn btn-sm btn-outline-secondary d-md-none"
            onclick="document.getElementById('sidebar').classList.toggle('open')">
        <i class="fas fa-bars"></i>
    </button>
    <span class="page-title">@ViewData["Title"]</span>
    <div class="ms-auto d-flex align-items-center gap-3">
        <span class="text-muted small fw-medium">
            <i class="fas fa-user-circle me-1 fs-6 align-middle"></i> @User.Identity?.Name
        </span>
    </div>
</div>

<div id="main-content">
    @RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>