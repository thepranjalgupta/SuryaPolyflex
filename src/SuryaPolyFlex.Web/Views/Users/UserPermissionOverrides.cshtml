@model List<SuryaPolyFlex.Domain.Entities.Core.UserPermission>
@{
    ViewData["Title"] = "User Permission Overrides";
    var userId = ViewBag.UserId as string;
    var userName = ViewBag.UserName as string;
    var allPermissions = ViewBag.AllPermissions as List<SuryaPolyFlex.Domain.Entities.Core.Permission> ?? new();
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0"><i class="fas fa-shield-alt me-2 text-info"></i>Permission Overrides</h4>
            <small class="text-muted">User: <strong>@userName</strong></small>
        </div>
        <a asp-action="Edit" asp-route-id="@userId" class="btn btn-sm btn-outline-secondary">← Back to User</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Active Overrides Section -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-info text-white">
            <h6 class="mb-0">
                <i class="fas fa-list me-2"></i>Active Permission Overrides
                <span class="badge bg-light text-dark float-end">@Model.Count</span>
            </h6>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <p class="text-muted text-center mb-0">No permission overrides assigned.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Permission</th>
                                <th>Module</th>
                                <th>Action</th>
                                <th>Status</th>
                                <th>Expires</th>
                                <th style="width: 100px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ov in Model.OrderBy(m => m.Permission.Module).ThenBy(m => m.Permission.Action))
                            {
                                var isExpired = ov.ExpiryDate.HasValue && ov.ExpiryDate < DateTime.Now;
                                <tr class="@(isExpired ? "opacity-50" : "")">
                                    <td>
                                        <code>@ov.Permission.Name</code>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@ov.Permission.Module</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary">@ov.Permission.Action</span>
                                    </td>
                                    <td>
                                        @if (ov.IsAllowed)
                                        {
                                            <span class="badge bg-success">ALLOW</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">DENY</span>
                                        }
                                        @if (isExpired)
                                        {
                                            <br />
                                            <small class="text-danger">EXPIRED</small>
                                        }
                                    </td>
                                    <td>
                                        @if (ov.ExpiryDate.HasValue)
                                        {
                                            <small>@ov.ExpiryDate.Value.ToString("MMM dd, yyyy")</small>
                                            @if (isExpired)
                                            {
                                                <span class="text-danger">(expired)</span>
                                            }
                                            else
                                            {
                                                <span class="text-success">(@(((ov.ExpiryDate.Value - DateTime.Now).Days) + 1) days left)</span>
                                            }
                                        }
                                        else
                                        {
                                            <small class="text-muted">Never</small>
                                        }
                                    </td>
                                    <td>
                                        <form asp-action="RevokeUserPermission" method="post" class="d-inline"
                                              onsubmit="return confirm('Revoke this override?')">
                                            <input type="hidden" name="userId" value="@userId" />
                                            <input type="hidden" name="permissionId" value="@ov.PermissionId" />
                                            <button type="submit" class="btn btn-xs btn-danger btn-sm"
                                                    title="Revoke override">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Grant/Deny New Override Section -->
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h6 class="mb-0"><i class="fas fa-plus me-2"></i>Grant/Deny Permission Override</h6>
        </div>
        <div class="card-body">
            <p class="text-muted small mb-3">
                <i class="fas fa-info-circle"></i>
                Select a permission to grant (allow) or deny to this user. Optional expiry sets auto-revocation.
            </p>

            @if (!allPermissions.Any())
            {
                <div class="alert alert-warning mb-0">
                    <i class="fas fa-exclamation-triangle"></i> No permissions available in the system.
                </div>
            }
            else
            {
                <!-- Grouped by Module -->
                <div class="row">
                    @{
                        var moduleGroups = allPermissions.GroupBy(p => p.Module).OrderBy(g => g.Key);
                    }

                    @foreach (var moduleGroup in moduleGroups)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card border-light">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0 text-dark">
                                        <span class="badge bg-secondary">@moduleGroup.Key</span>
                                    </h6>
                                </div>
                                <div class="card-body p-3">
                                    <div class="list-group list-group-sm">
                                        @foreach (var perm in moduleGroup.OrderBy(p => p.Action))
                                        {
                                            var hasOverride = Model.Any(m => m.PermissionId == perm.Id && !((m.ExpiryDate.HasValue && m.ExpiryDate < DateTime.Now)));
                                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                                <div class="flex-grow-1">
                                                    <small class="fw-medium">@perm.Action</small>
                                                    <br />
                                                    <small class="text-muted">@perm.Description</small>
                                                </div>
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <form asp-action="GrantUserPermission" method="post" class="d-inline"
                                                          title="Grant (ALLOW) this permission">
                                                        <input type="hidden" name="userId" value="@userId" />
                                                        <input type="hidden" name="permissionId" value="@perm.Id" />
                                                        <button type="submit" class="btn btn-success"
                                                                @(hasOverride ? "disabled" : "")>
                                                            <i class="fas fa-check"></i>
                                                        </button>
                                                    </form>
                                                    <form asp-action="DenyUserPermission" method="post" class="d-inline"
                                                          title="Deny (BLOCK) this permission">
                                                        <input type="hidden" name="userId" value="@userId" />
                                                        <input type="hidden" name="permissionId" value="@perm.Id" />
                                                        <button type="submit" class="btn btn-danger"
                                                                @(hasOverride ? "disabled" : "")>
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Expiry Days Modal -->
                <div class="modal fade" id="expiryModal" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Set Expiry Duration</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <label class="form-label">Days until expiry (leave empty for no expiry):</label>
                                <input type="number" id="expiryDays" class="form-control" min="1" max="365" placeholder="e.g., 30" />
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                <button type="button" class="btn btn-primary" onclick="submitWithExpiry()">Apply</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Legend -->
    <div class="alert alert-info mt-4 small">
        <strong><i class="fas fa-circle-info me-2"></i>Legend:</strong><br />
        <span class="badge bg-success">ALLOW</span> = User is explicitly granted this permission (overrides role)<br />
        <span class="badge bg-danger">DENY</span> = User is explicitly blocked from this permission (overrides role)<br />
        Overrides with dates are auto-revoked when expired.
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
