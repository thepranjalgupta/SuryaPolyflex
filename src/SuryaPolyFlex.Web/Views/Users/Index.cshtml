@using SuryaPolyFlex.Domain.Enums
@model List<SuryaPolyFlex.Application.Features.Users.UserDto>
@{ ViewData["Title"] = "Users"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">System Users</h4>
    <a asp-action="Create" class="btn btn-primary btn-sm">+ Add User</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="get" class="d-flex gap-2 mb-3">
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control form-control-sm w-25"
                   placeholder="Search name or email..." />
            <button class="btn btn-sm btn-outline-secondary">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-danger">Clear</a>
            }
        </form>

        <div class="table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Authority</th>
                        <th>Department</th>
                        <th>Employee</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>Last Login</th>
                        <th>Status</th>
                        <th style="width:220px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted">No users found.</td></tr>
                    }
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@u.FullName</td>
                            <td class="small">@u.Email</td>
                            <td>
                                @switch(u.AuthorityRole)
                                {
                                    case AuthorityRole.Admin:
                                        <span class="badge bg-danger">Admin</span>
                                        break;
                                    case AuthorityRole.DepartmentHead:
                                        <span class="badge bg-warning">DeptHead</span>
                                        break;
                                    case AuthorityRole.Manager:
                                        <span class="badge bg-info">Manager</span>
                                        break;
                                    case AuthorityRole.Employee:
                                        <span class="badge bg-secondary">Employee</span>
                                        break;
                                }
                            </td>
                            <td class="small">@u.DepartmentName ?? "-"</td>
                            <td class="small">@u.EmployeeName ?? "-"</td>
                            <td class="small">@u.Phone</td>
                            <td>
                                @foreach (var role in u.Roles)
                                {
                                    <span class="badge bg-primary" style="font-size: 0.75rem;">@role</span>
                                }
                            </td>
                            <td class="small text-muted">
                                @(u.LastLoginAt.HasValue
                                    ? u.LastLoginAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                    : "Never")
                            </td>
                            <td>
                                @if (u.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Edit" asp-route-id="@u.Id"
                                       class="btn btn-outline-primary" title="Edit user">Edit</a>
                                    <a asp-action="UserPermissionOverrides" asp-route-userId="@u.Id"
                                       class="btn btn-outline-info" title="Manage permissions">
                                        <i class="fas fa-shield-alt"></i>
                                    </a>
                                    <a asp-action="ResetPassword" asp-route-id="@u.Id"
                                       class="btn btn-outline-warning" title="Reset password">Pwd</a>
                                    <form asp-action="ToggleActive" asp-route-id="@u.Id"
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" 
                                                class="btn btn-sm @(u.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                                                title="@(u.IsActive ? "Deactivate user" : "Activate user")">
                                            @(u.IsActive ? "Deact" : "Act")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>