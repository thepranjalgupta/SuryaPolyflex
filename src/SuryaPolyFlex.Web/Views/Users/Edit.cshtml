@model SuryaPolyFlex.Application.Features.Users.EditUserDto
@{ ViewData["Title"] = "Edit User"; }

<div class="card shadow-sm mx-auto" style="max-width:520px">
    <div class="card-header bg-warning">
        <h5 class="mb-0">Edit User</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label fw-semibold">Phone</label>
                    <input asp-for="Phone" class="form-control" />
                </div>

                <div class="col-md-6">
                    <label asp-for="RoleName" class="form-label fw-semibold">Role <span class="text-danger">*</span></label>
                    <select asp-for="RoleName" asp-items="ViewBag.Roles" class="form-select">
                        <option value="">-- Select Role --</option>
                    </select>
                    <span asp-validation-for="RoleName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="DepartmentId" class="form-label fw-semibold">Department</label>
                    <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-select">
                        <option value="">-- None --</option>
                    </select>
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Active</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning">Update</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />