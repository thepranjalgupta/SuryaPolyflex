@model SuryaPolyFlex.Application.Features.GateEntry.CreateGateEntryDto
@{ ViewData["Title"] = "New Gate Entry"; }

<div class="card shadow-sm mx-auto" style="max-width:580px">
    <div class="card-header bg-primary text-white"><h5 class="mb-0">New Gate Entry</h5></div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="VendorId" class="form-label fw-semibold">Vendor <span class="text-danger">*</span></label>
                    <select asp-for="VendorId" asp-items="ViewBag.Vendors" class="form-select">
                        <option value="">-- Select Vendor --</option>
                    </select>
                    <span asp-validation-for="VendorId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="POId" class="form-label fw-semibold">Purchase Order</label>
                    <select asp-for="POId" asp-items="ViewBag.PurchaseOrders" class="form-select">
                        <option value="">-- Select PO (optional) --</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="VehicleNumber" class="form-label fw-semibold">Vehicle Number</label>
                    <input asp-for="VehicleNumber" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="DriverName" class="form-label fw-semibold">Driver Name</label>
                    <input asp-for="DriverName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="EntryDateTime" class="form-label fw-semibold">Entry Date & Time <span class="text-danger">*</span></label>
                    <input asp-for="EntryDateTime" type="datetime-local" class="form-control" />
                    <span asp-validation-for="EntryDateTime" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="ReceivedBy" class="form-label fw-semibold">Received By <span class="text-danger">*</span></label>
                    <input asp-for="ReceivedBy" class="form-control"
                           value="@User.Identity?.Name" />
                    <span asp-validation-for="ReceivedBy" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Remarks" class="form-label fw-semibold">Remarks</label>
                    <textarea asp-for="Remarks" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Record Entry</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>