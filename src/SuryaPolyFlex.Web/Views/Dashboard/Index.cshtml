@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="fas fa-file-alt text-primary fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">Open Indents</div>
                    <div class="fw-bold fs-4">@ViewBag.OpenIndents</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="fas fa-receipt text-success fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">Open Sales Orders</div>
                    <div class="fw-bold fs-4">@ViewBag.OpenSOs</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="fas fa-tasks text-warning fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">Active Job Cards</div>
                    <div class="fw-bold fs-4">@ViewBag.ActiveJobCards</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3">
                    <i class="fas fa-shipping-fast text-info fa-lg"></i>
                </div>
                <div>
                    <div class="text-muted small">Pending Dispatches</div>
                    <div class="fw-bold fs-4">@ViewBag.PendingDispatches</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold bg-white">
                <i class="fas fa-clock text-warning me-2"></i>Pending Approvals
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>Type</th><th>Number</th><th>Date</th></tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.PendingIndents != null)
                        {
                            foreach (var item in ViewBag.PendingIndents)
                            {
                                <tr>
                                    <td><span class="badge bg-warning text-dark">Indent</span></td>
                                    <td>@item.IndentNumber</td>
                                    <td class="small">@item.IndentDate.ToString("dd MMM")</td>
                                </tr>
                            }
                        }
                        @if (ViewBag.PendingIndents == null || ((IEnumerable<dynamic>)ViewBag.PendingIndents).Count() == 0)
                        {
                            <tr><td colspan="3" class="text-center text-muted small py-3">No pending approvals</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold bg-white">
                <i class="fas fa-exclamation-triangle text-danger me-2"></i>Low Stock Items
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>Item</th><th>On Hand</th><th>Min Level</th></tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.LowStockItems != null)
                        {
                            foreach (var item in ViewBag.LowStockItems)
                            {
                                <tr>
                                    <td>@item.Name</td>
                                    <td class="text-danger fw-semibold">@item.OnHandQty</td>
                                    <td class="text-muted">@item.MinStockLevel</td>
                                </tr>
                            }
                        }
                        @if (ViewBag.LowStockItems == null || ((IEnumerable<dynamic>)ViewBag.LowStockItems).Count() == 0)
                        {
                            <tr><td colspan="3" class="text-center text-muted small py-3">All stock levels OK</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>